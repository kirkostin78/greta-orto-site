---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
	title: string;
	description: string;
	noindex?: boolean;
	ogImage?: string;
	bodyClass?: string;
}

const { title, description, noindex = true, ogImage, bodyClass } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageAbs = ogImage ? new URL(ogImage, Astro.site).toString() : new URL("/greta-orto-logo.png", Astro.site).toString();

const orgJsonLd = {
	"@context": "https://schema.org",
	"@type": ["Dentist", "MedicalBusiness", "LocalBusiness"],
	name: "Грета Орто",
	alternateName: "Greta Orto",
	url: Astro.site?.toString(),
	logo: new URL("/greta-orto-logo.png", Astro.site).toString(),
	description:
		"Центр прозрачной ортодонтии в Санкт-Петербурге. Элайнеры, брекет-системы, исправление прикуса.",
	areaServed: {
		"@type": "City",
		name: "Санкт-Петербург",
	},
	medicalSpecialty: ["Orthodontic", "Dentistry"],
};
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />

		<meta property="og:type" content="website" />
		<meta property="og:locale" content="ru_RU" />
		<meta property="og:site_name" content="Грета Орто" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageAbs} />
		<meta name="twitter:card" content="summary_large_image" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Nunito:wght@700;800&display=swap"
			rel="stylesheet"
		/>

		<script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
	</head>
	<body class={bodyClass}>
		<SiteHeader />
		<main>
			<slot />
		</main>
		<SiteFooter />

		<style is:global>
			:root {
				--gold: #b08a55;
				--gold-dark: #967449;
				--cream: #f7eee0;
				--cream-dark: #efe2c9;
				--grey: #e2e2e2;
				--grey-soft: #f1f1f1;
				--light: #fafafa;
				--dark: #2f2f2f;
				--text: #3a3a3a;
				--muted: #6b6b6b;
			}

			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				padding: 0;
			}

			body {
				background: var(--light);
				color: var(--text);
				font-family: "Manrope", system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
				-webkit-font-smoothing: antialiased;
				line-height: 1.6;
			}

			.container {
				max-width: 1100px;
				margin: 0 auto;
				padding: 0 24px;
			}

			.container-narrow {
				max-width: 820px;
				margin: 0 auto;
				padding: 0 24px;
			}

			h1,
			h2,
			h3,
			h4 {
				font-family: "Nunito", system-ui, sans-serif;
				color: var(--dark);
				line-height: 1.2;
				margin: 0 0 16px;
			}

			h1 {
				font-size: clamp(30px, 5vw, 48px);
				margin-bottom: 20px;
			}

			h2 {
				font-size: clamp(24px, 3.6vw, 32px);
				margin-top: 48px;
				margin-bottom: 18px;
			}

			h3 {
				font-size: clamp(20px, 2.6vw, 24px);
				margin-top: 28px;
			}

			p {
				margin: 0 0 14px;
			}

			a {
				color: var(--gold);
				text-decoration: none;
			}

			a:hover {
				text-decoration: underline;
			}

			ul,
			ol {
				padding-left: 22px;
				margin: 0 0 16px;
			}

			li {
				margin-bottom: 6px;
			}

			.card {
				background: #fff;
				border: 1px solid var(--grey);
				border-radius: 12px;
				padding: 24px;
			}

			.btn {
				display: inline-block;
				padding: 13px 22px;
				background: var(--gold);
				color: #fff;
				text-decoration: none;
				border-radius: 8px;
				font-weight: 700;
				font-size: 15px;
				transition: background 0.15s;
			}

			.btn:hover {
				background: var(--gold-dark);
				text-decoration: none;
			}

			.btn-outline {
				background: transparent;
				color: var(--gold);
				border: 2px solid var(--gold);
				padding: 11px 20px;
			}

			.btn-outline:hover {
				background: var(--gold);
				color: #fff;
			}

			main {
				min-height: 60vh;
			}
		</style>
	</body>
</html>
