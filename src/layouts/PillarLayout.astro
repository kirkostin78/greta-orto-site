---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";

interface Props {
	title: string;
	description: string;
	h1: string;
	lead?: string;
	breadcrumbs?: { label: string; href?: string }[];
	noindex?: boolean;
	updated?: string;
	author?: string;
	procedureSchema?: {
		name: string;
		description: string;
		bodyLocation?: string;
	};
}

const {
	title,
	description,
	h1,
	lead,
	breadcrumbs = [],
	noindex = true,
	updated,
	author,
	procedureSchema,
} = Astro.props;

const procedureJsonLd = procedureSchema
	? {
			"@context": "https://schema.org",
			"@type": "MedicalProcedure",
			name: procedureSchema.name,
			description: procedureSchema.description,
			bodyLocation: procedureSchema.bodyLocation ?? "Зубы",
			procedureType: {
				"@type": "MedicalProcedureType",
				name: "Therapeutic",
			},
		}
	: null;
---

<BaseLayout title={title} description={description} noindex={noindex}>
	<article class="pillar">
		<div class="container-narrow">
			{breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}

			<header class="pillar-header">
				<h1>{h1}</h1>
				{lead && <p class="lead">{lead}</p>}
				{
					(updated || author) && (
						<div class="meta">
							{author && (
								<span>
									Автор: <strong>{author}</strong>
								</span>
							)}
							{updated && (
								<span>
									Обновлено: <time datetime={updated}>{updated}</time>
								</span>
							)}
						</div>
					)
				}
			</header>

			<div class="pillar-body">
				<slot />
			</div>
		</div>
	</article>

	{procedureJsonLd && <script type="application/ld+json" set:html={JSON.stringify(procedureJsonLd)} />}
</BaseLayout>

<style>
	.pillar {
		padding: 40px 0 var(--space-section);
	}

	.pillar-header {
		margin-bottom: 40px;
		padding-bottom: 32px;
		border-bottom: 1px solid var(--line);
	}

	.lead {
		font-size: clamp(17px, 2vw, 21px);
		color: var(--muted);
		line-height: 1.6;
		margin: 16px 0 18px;
		max-width: 60ch;
	}

	.meta {
		display: flex;
		flex-wrap: wrap;
		gap: 6px 24px;
		font-size: 13.5px;
		color: var(--muted);
		margin-top: 12px;
	}

	.meta strong {
		color: var(--ink);
	}

	.pillar-body :global(h2) {
		margin-top: 56px;
		margin-bottom: 18px;
	}

	.pillar-body :global(h3) {
		margin-top: 32px;
		margin-bottom: 12px;
	}

	.pillar-body :global(figure) {
		margin: 32px 0;
	}

	.pillar-body :global(blockquote) {
		border-left: 3px solid var(--gold);
		padding: 16px 22px;
		background: var(--cream);
		border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
		margin: 26px 0;
		color: var(--ink);
		font-style: italic;
		font-size: 17px;
	}

	.pillar-body :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 24px 0;
		font-size: 14.5px;
	}

	.pillar-body :global(th),
	.pillar-body :global(td) {
		padding: 12px 14px;
		border-bottom: 1px solid var(--line);
		text-align: left;
		vertical-align: top;
	}

	.pillar-body :global(th) {
		background: var(--surface-warm);
		color: var(--ink);
		font-weight: 700;
	}
</style>
