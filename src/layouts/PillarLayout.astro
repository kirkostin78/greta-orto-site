---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";

interface Props {
	title: string;
	description: string;
	h1: string;
	lead?: string;
	breadcrumbs?: { label: string; href?: string }[];
	noindex?: boolean;
	updated?: string;
	author?: string;
	procedureSchema?: {
		name: string;
		description: string;
		bodyLocation?: string;
	};
}

const {
	title,
	description,
	h1,
	lead,
	breadcrumbs = [],
	noindex = true,
	updated,
	author,
	procedureSchema,
} = Astro.props;

const procedureJsonLd = procedureSchema
	? {
			"@context": "https://schema.org",
			"@type": "MedicalProcedure",
			name: procedureSchema.name,
			description: procedureSchema.description,
			bodyLocation: procedureSchema.bodyLocation ?? "Зубы",
			procedureType: {
				"@type": "MedicalProcedureType",
				name: "Therapeutic",
			},
		}
	: null;
---

<BaseLayout title={title} description={description} noindex={noindex}>
	<article class="pillar">
		<div class="container-narrow">
			{breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}

			<header class="pillar-header">
				<h1>{h1}</h1>
				{lead && <p class="lead">{lead}</p>}
				{
					(updated || author) && (
						<div class="meta">
							{author && (
								<span>
									Автор: <strong>{author}</strong>
								</span>
							)}
							{updated && (
								<span>
									Обновлено: <time datetime={updated}>{updated}</time>
								</span>
							)}
						</div>
					)
				}
			</header>

			<div class="pillar-body">
				<slot />
			</div>
		</div>
	</article>

	{procedureJsonLd && <script type="application/ld+json" set:html={JSON.stringify(procedureJsonLd)} />}
</BaseLayout>

<style>
	.pillar {
		padding: 32px 0 64px;
	}

	.pillar-header {
		margin-bottom: 36px;
		padding-bottom: 28px;
		border-bottom: 1px solid var(--grey);
	}

	.lead {
		font-size: clamp(17px, 2vw, 20px);
		color: var(--text);
		line-height: 1.55;
		margin: 16px 0 18px;
	}

	.meta {
		display: flex;
		flex-wrap: wrap;
		gap: 6px 18px;
		font-size: 13px;
		color: var(--muted);
		margin-top: 8px;
	}

	.pillar-body :global(h2) {
		margin-top: 48px;
	}

	.pillar-body :global(figure) {
		margin: 28px 0;
	}

	.pillar-body :global(blockquote) {
		border-left: 4px solid var(--gold);
		padding: 12px 18px;
		background: var(--cream);
		border-radius: 0 8px 8px 0;
		margin: 22px 0;
		color: #5b4f3a;
		font-style: italic;
	}
</style>
