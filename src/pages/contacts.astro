---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Контакты — Грета Орто";
const description = "Контакты центра прозрачной ортодонтии Грета Орто: адрес в Санкт-Петербурге, телефон и режим работы.";
---

<BaseLayout title={title} description={description}>
	<h1>Контакты</h1>

	<section class="card">
		<p><strong>Клиника:</strong> Грета Орто</p>
		<p><strong>Позиционирование:</strong> центр прозрачной ортодонтии</p>
		<p><strong>Город:</strong> Санкт-Петербург</p>
		<p><strong>Телефон:</strong> +7 (812) 603-83-00</p>
		<p><strong>Сайт-визитка (текущий):</strong> <a href="https://gretaorto.ru">gretaorto.ru</a></p>
	</section>

	<section class="card">
		<h2>Запись на консультацию</h2>
		<p>
			Оставьте заявку по телефону или на действующем сайте. В следующих итерациях добавим онлайн-виджет
			записи прямо на этот сайт.
		</p>
		<p><a class="btn" href="https://gretaorto.ru">Перейти на действующий сайт</a></p>
	</section>
</BaseLayout>
