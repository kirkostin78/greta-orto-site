---
import PillarLayout from "../../layouts/PillarLayout.astro";
import CTA from "../../components/CTA.astro";
import FAQ from "../../components/FAQ.astro";

const title = "Гнатология и лечение ВНЧС в Санкт-Петербурге — Грета Орто";
const description =
	"Гнатолог в СПб: диагностика и лечение дисфункции височно-нижнечелюстного сустава. Щелчки, боль, ограничение открывания рта.";

const faq = [
	{
		q: "Кто такой гнатолог?",
		a: "Стоматолог, который занимается работой жевательного аппарата как системой: зубы + сустав + мышцы. Гнатолог нужен, когда у пациента есть щелчки, боли, головные боли, бруксизм или сложный прикус.",
	},
	{
		q: "Что такое ВНЧС?",
		a: "Височно-нижнечелюстной сустав — парный сустав, который соединяет нижнюю челюсть с черепом. Через него проходят все движения при разговоре, жевании, зевании.",
	},
	{
		q: "Когда стоит идти к гнатологу?",
		a: "Если щёлкает или хрустит сустав, болит при открывании, утром скованы челюсти, есть головные боли в висках, шум в ушах, скрежет зубами во сне.",
	},
];
---

<PillarLayout
	title={title}
	description={description}
	h1="Гнатология и лечение ВНЧС"
	lead="Гнатология — раздел стоматологии о работе жевательного аппарата как системы: зубы, мышцы, височно-нижнечелюстной сустав. Без гнатолога стабильное исправление сложного прикуса невозможно."
	breadcrumbs={[{ label: "Главная", href: "/" }, { label: "Гнатология" }]}
>
	<h2>Симптомы дисфункции ВНЧС</h2>
	<ul>
		<li>Щелчки, хруст или щелчок-блок при открывании рта</li>
		<li>Боль в области уха, виска, при жевании</li>
		<li>Ограничение открывания рта</li>
		<li>Утренняя скованность челюсти, скрежет зубов во сне (бруксизм)</li>
		<li>Головные боли неясного происхождения, шум в ушах</li>
		<li>Несимметричное лицо, смещение подбородка при открывании</li>
	</ul>

	<h2>Диагностика</h2>
	<p>
		Очный осмотр, пальпация мышц, оценка движений сустава. Инструментальная диагностика: КЛКТ или МРТ
		сустава, аксиография, диагностические капы для проверки гипотезы. Совместная работа с ортодонтом
		обязательна.
	</p>

	<h2>Лечение</h2>
	<p>
		Зависит от диагноза: миорелаксационные капы, ортодонтическое лечение, физиотерапия, в редких случаях —
		хирургия. Цель — снять воспаление в суставе, сбалансировать мышцы и установить зубы в физиологически
		правильную окклюзию.
	</p>

	<CTA
		heading="Консультация гнатолога"
		text="Запишитесь на приём для оценки состояния сустава и составления плана лечения."
	/>

	<FAQ items={faq} />
</PillarLayout>
