---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "О клинике — Грета Орто";
const description = "Грета Орто — центр прозрачной ортодонтии в Санкт-Петербурге. Подход клиники, ценности и принципы лечения.";
---

<BaseLayout title={title} description={description}>
	<h1>О клинике Грета Орто</h1>
	<p>
		Грета Орто — центр прозрачной ортодонтии в Санкт-Петербурге. Мы строим лечение на диагностике,
		прогнозируемости результата и понятной коммуникации с пациентом.
	</p>

	<section class="card">
		<h2>Наш подход</h2>
		<p>Каждый клинический случай начинается с детального анализа и персонального плана лечения.</p>
		<p>Пациент на старте получает прозрачную картину: этапы, сроки, контрольные точки и рекомендации.</p>
	</section>

	<section class="card">
		<h2>Ценности клиники</h2>
		<p>Точность, медицинская этика, уважение к времени пациента и доказательный подход.</p>
		<p>Мы делаем ставку на долгосрочный стабильный результат, а не на быстрые компромиссные решения.</p>
	</section>
</BaseLayout>
