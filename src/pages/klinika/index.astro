---
import PillarLayout from "../../layouts/PillarLayout.astro";
import CTA from "../../components/CTA.astro";

const title = "О клинике Грета Орто — центр прозрачной ортодонтии в СПб";
const description =
	"Клиника Грета Орто в Санкт-Петербурге: команда, оборудование, подход к лечению. Прозрачная ортодонтия с цифровым планированием результата.";
---

<PillarLayout
	title={title}
	description={description}
	h1="Клиника Грета Орто"
	lead="Центр прозрачной ортодонтии в Санкт-Петербурге. Мы строим лечение на цифровой диагностике, прогнозируемости результата и понятной коммуникации с пациентом."
	breadcrumbs={[{ label: "Главная", href: "/" }, { label: "Клиника" }]}
>
	<h2>Наш подход</h2>
	<p>
		Любое ортодонтическое лечение в Грета Орто начинается с цифровой диагностики и подробного плана.
		Пациент на старте видит цифровой setup — как будут перемещаться зубы шаг за шагом — и точно понимает,
		какой результат получит на выходе.
	</p>

	<h2>Оборудование</h2>
	<p>
		3D-сканер, конусно-лучевой томограф, цифровая фотопротокол-станция. Все этапы лечения фиксируются
		фото-сравнением для контроля прогресса.
	</p>

	<h2>Ценности</h2>
	<ul>
		<li>Точная диагностика и доказательный подход</li>
		<li>Прозрачность стоимости с первого визита</li>
		<li>Долгосрочный стабильный результат вместо быстрых компромиссов</li>
		<li>Уважение к времени пациента — приёмы по графику</li>
	</ul>

	<h2>Что у нас есть</h2>
	<ul>
		<li><a href="/elajnery/">Элайнеры</a> всех ведущих брендов</li>
		<li><a href="/brekety/">Брекет-системы</a> любых типов</li>
		<li><a href="/gnatologiya/">Гнатология и работа с ВНЧС</a></li>
		<li><a href="/detskaya-ortodontiya/">Детская ортодонтия</a></li>
		<li><a href="/retentsiya/">Ретенция и контроль результата</a></li>
	</ul>

	<CTA />
</PillarLayout>
