---
import PillarLayout from "../../layouts/PillarLayout.astro";
import CTA from "../../components/CTA.astro";
import FAQ from "../../components/FAQ.astro";

const title = "Элайнеры в Санкт-Петербурге — Грета Орто";
const description =
	"Элайнеры в СПб: цифровая диагностика, прозрачный план лечения, контроль на каждом этапе. Расчёт стоимости и сроков на бесплатной консультации.";

const faq = [
	{
		q: "Что такое элайнеры?",
		a: "Прозрачные съёмные капы из биосовместимого пластика, которые мягко перемещают зубы по индивидуальному цифровому плану. Каждые 1–2 недели вы переходите на следующую пару — и зубы постепенно встают в нужное положение.",
	},
	{
		q: "Сколько стоят элайнеры в Санкт-Петербурге?",
		a: "Стоимость зависит от сложности случая и выбранного бренда (Invisalign, FlexiLigner, Spark, Star Smile, Eurokappa, Angel и др.). На консультации вы получите фиксированную цену за весь курс лечения.",
	},
	{
		q: "Сколько носить элайнеры?",
		a: "В среднем — от 6 до 18 месяцев в зависимости от исходной ситуации. Капы носят 22 часа в сутки, снимают только на еду и гигиену.",
	},
	{
		q: "Подходят ли элайнеры именно мне?",
		a: "Окончательно ответит врач после очной диагностики и 3D-сканирования. Элайнеры эффективны для большинства случаев скученности, промежутков и нарушений прикуса лёгкой и средней степени.",
	},
	{
		q: "Чем элайнеры лучше брекетов?",
		a: "Они прозрачные, съёмные, не натирают, не требуют диеты. Гигиена зубов — как обычно. Минусы: дисциплина (надо носить 22 часа) и более высокая цена в средних случаях.",
	},
];
---

<PillarLayout
	title={title}
	description={description}
	h1="Элайнеры в Санкт-Петербурге"
	lead="Прозрачные капы для пошагового выравнивания зубов. В Грета Орто вы видите цифровой план перемещения зубов ещё до начала лечения — и понимаете, какой будет результат."
	breadcrumbs={[{ label: "Главная", href: "/" }, { label: "Элайнеры" }]}
	procedureSchema={{
		name: "Лечение элайнерами",
		description: "Ортодонтическое лечение с использованием прозрачных съёмных капп для выравнивания зубов и исправления прикуса.",
	}}
>
	<h2>Как проходит лечение элайнерами</h2>
	<p>
		Этап за этапом — от первой консультации до ретенции. На старте мы делаем цифровое 3D-сканирование
		зубов, фото-протокол и при необходимости КЛКТ. На основании этих данных составляется индивидуальный
		план перемещения зубов с визуализацией каждого шага.
	</p>
	<p>
		После согласования плана изготавливается набор прозрачных капп. Вы носите каждую пару 1–2 недели по
		22 часа в сутки и переходите на следующую. Раз в 4–8 недель — контрольный визит к ортодонту.
	</p>

	<h2>Кому подходят элайнеры</h2>
	<p>
		Элайнеры эффективны при скученности зубов, промежутках (трэмах и диастемах), большинстве типов
		нарушения прикуса лёгкой и средней сложности. В сложных случаях возможна комбинированная тактика —
		элайнеры + миниимпланты + точечная коррекция.
	</p>

	<h2>Сроки и стоимость</h2>
	<p>
		Срок лечения в среднем — от 6 до 18 месяцев. Стоимость зависит от количества капп, бренда и сложности
		случая. Финальная цена фиксируется на старте — без доплат «по ходу».
	</p>

	<h2>Бренды элайнеров, с которыми мы работаем</h2>
	<ul>
		<li><a href="/elajnery/brendy/flexiligner/">FlexiLigner</a> — российский бренд с прозрачным ценообразованием</li>
		<li><a href="/elajnery/brendy/invisalign/">Invisalign</a> — мировой стандарт, оригинальные элайнеры</li>
		<li><a href="/elajnery/brendy/spark/">Spark</a> — премиальные элайнеры с улучшенной прозрачностью</li>
		<li><a href="/elajnery/brendy/star-smile/">Star Smile</a> — российская система с большой клинической базой</li>
		<li><a href="/elajnery/brendy/eurokappa/">EuroKappa</a> — европейское решение среднего ценового сегмента</li>
		<li><a href="/elajnery/brendy/angel/">Angel Aligners</a> — азиатский премиум-бренд</li>
	</ul>

	<h2>Связанные темы</h2>
	<ul>
		<li><a href="/elajnery/cena/">Цена элайнеров в СПб</a></li>
		<li><a href="/elajnery/srok-nosheniya/">Сколько носить элайнеры</a></li>
		<li><a href="/elajnery/ili-brekety/">Элайнеры или брекеты — что выбрать</a></li>
		<li><a href="/kapy/">Капа для зубов — что это и зачем</a></li>
		<li><a href="/retentsiya/">Ретенция после элайнеров</a></li>
	</ul>

	<CTA
		heading="Бесплатная консультация ортодонта"
		text="Сделаем 3D-снимок, покажем план лечения и назовём точную стоимость до начала."
	/>

	<FAQ items={faq} />
</PillarLayout>
