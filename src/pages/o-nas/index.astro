---
import PillarLayout from "../../layouts/PillarLayout.astro";
import CTA from "../../components/CTA.astro";

const title = "О бренде Greta Orto — история и философия клиники";
const description =
	"Грета Орто — почему именно так называется клиника, история создания, философия прозрачной ортодонтии и команда, стоящая за брендом.";
---

<PillarLayout
	title={title}
	description={description}
	h1="О бренде Greta Orto"
	lead="Грета Орто — авторская клиника, созданная вокруг идеи прозрачной ортодонтии: пациент должен видеть и понимать своё лечение от первой до последней минуты."
	breadcrumbs={[{ label: "Главная", href: "/" }, { label: "О бренде" }]}
>
	<h2>История клиники</h2>
	<p>
		Клиника основана командой ортодонтов с многолетним опытом частной практики. Идея — собрать в одной
		точке полный цикл ортодонтического лечения, от детской профилактики до сложных взрослых случаев с
		гнатологией.
	</p>

	<h2>Почему «прозрачная» ортодонтия</h2>
	<p>
		«Прозрачная» — это не только про технологии (элайнеры, цифровое моделирование), но и про принцип
		общения с пациентом. Никаких «врач знает лучше, не вникайте». Вы видите план, цены, этапы — и принимаете
		решение осознанно.
	</p>

	<h2>Команда</h2>
	<p>
		<a href="/ortodont/komanda/">Профайлы врачей</a>: образование, специализация, кейсы.
	</p>

	<CTA />
</PillarLayout>
