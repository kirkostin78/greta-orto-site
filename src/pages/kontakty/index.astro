---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { siteLinks } from "../../data/siteLinks";

const title = "Контакты — Грета Орто, Санкт-Петербург, ул. Марата 68";
const description =
	"Адрес клиники Грета Орто: Санкт-Петербург, ул. Марата 68. Телефоны +7 (812) 501-12-15, +7 (994) 416-85-68. Режим работы Пн–Вс, 9:00–21:00 без выходных.";
---

<BaseLayout title={title} description={description}>
	<div class="container-narrow contacts">
		<Breadcrumbs items={[{ label: "Главная", href: "/" }, { label: "Контакты" }]} />

		<h1>Контакты</h1>
		<p class="lead">
			Запишитесь на первичную консультацию ортодонта (1 час, 1 900 ₽) или задайте вопрос — городской и
			мобильный телефоны клиники, а также <strong>Telegram</strong> и <strong>Max</strong> (см. шапку
			сайта).
		</p>

		<div class="cards">
			<section class="card">
				<h2>Связаться с клиникой</h2>
				<dl>
					<dt>Городской телефон</dt>
					<dd><a href="tel:+78125011215">+7 (812) 501-12-15</a></dd>
					<dt>Мобильный</dt>
					<dd><a href="tel:+79944168568">+7 (994) 416-85-68</a></dd>
					<dt>Email</dt>
					<dd><a href="mailto:gretaorto@yandex.ru">gretaorto@yandex.ru</a></dd>
					<dt>Адрес</dt>
					<dd>191119, Санкт-Петербург, ул. Марата, 68, лит. А, пом. 9-н</dd>
					<dt>Режим работы</dt>
					<dd>Пн–Вс, 9:00–21:00 · без выходных</dd>
					<dt>ВКонтакте</dt>
					<dd><a href="https://vk.com/gretaorto" rel="noopener" target="_blank">vk.com/gretaorto</a></dd>
				</dl>
			</section>

			<section class="card">
				<h2>Запись на консультацию</h2>
				<p>
					Первичный приём ортодонта длится 1 час, стоимость 1 900 ₽. Врач проводит осмотр, делает
					фото-протокол, обсуждает с вами задачи и предлагает варианты лечения. Решение о следующих
					шагах вы принимаете спокойно, без давления.
				</p>
				<p class="contact-actions">
					<a class="btn" href={siteLinks.onlineBooking} target="_blank" rel="noopener"
						>Онлайн-запись: врач и время</a
					>
					<a class="btn" href="tel:+78125011215">Позвонить</a>
					<a class="btn btn-outline" href={siteLinks.telegram} target="_blank" rel="noopener"
						>Написать в Telegram</a
					>
					<a class="btn btn-outline" href={siteLinks.max} target="_blank" rel="noopener"
						>Написать в Max</a
					>
				</p>
				<p class="muted-note">
					Пациентам из других городов лечение на элайнерах удобно — визиты раз в 3–6 месяцев можно
					планировать заранее.
				</p>
			</section>
		</div>

		<section class="card requisites">
			<h2>Реквизиты</h2>
			<dl>
				<dt>Юр.лицо</dt>
				<dd>ООО «НТВ»</dd>
				<dt>ИНН</dt>
				<dd>7805819155</dd>
				<dt>КПП</dt>
				<dd>784001001</dd>
				<dt>ОГРН</dt>
				<dd>1247800108148</dd>
				<dt>Юр.адрес</dt>
				<dd>191119, г. Санкт-Петербург, ул. Марата, д. 68, лит. А, пом. 9-н</dd>
				<dt>Ген.директор</dt>
				<dd>Костин Кирилл Александрович</dd>
			</dl>
		</section>
	</div>
</BaseLayout>

<style>
	.contacts {
		padding: 32px 0 56px;
	}

	.lead {
		font-size: 17px;
		color: var(--muted);
		margin-bottom: 24px;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 16px;
	}

	dl {
		display: grid;
		grid-template-columns: max-content 1fr;
		gap: 8px 18px;
		margin: 0;
	}

	dt {
		color: var(--muted);
		font-size: 14px;
	}

	dd {
		margin: 0;
		font-weight: 600;
	}

	.contact-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.muted-note {
		font-size: 13.5px;
		color: var(--muted);
		font-style: italic;
		margin-top: 12px;
	}

	.requisites {
		margin-top: 16px;
	}
</style>
