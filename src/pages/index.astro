---
const title = "Грета Орто — центр прозрачной ортодонтии в Санкт-Петербурге";
const description = "Центр прозрачной ортодонтии в Санкт-Петербурге. Элайнеры, брекет-системы, комплексная стоматология. Скоро здесь появится новый сайт.";
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content="noindex, nofollow" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600&family=Nunito:wght@600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<main>
			<img class="logo" src="/greta-orto-logo.png" alt="Логотип Грета Орто" />
			<p class="tagline">Центр прозрачной ортодонтии</p>
			<p class="subtagline">Новый сайт в&nbsp;разработке. Скоро здесь появится полноценный&nbsp;ресурс.</p>
			<a class="btn" href="https://gretaorto.ru" rel="noopener">Перейти на действующий сайт</a>
			<footer>© Грета Орто · {new Date().getFullYear()}</footer>
		</main>

		<style is:global>
			:root {
				--gold: #b08a55;
				--grey: #e2e2e2;
				--light: #fafafa;
				--dark: #2f2f2f;
			}
			*, *::before, *::after { box-sizing: border-box; }
			html, body { margin: 0; padding: 0; }
			body {
				min-height: 100vh;
				display: grid;
				place-items: center;
				background: var(--light);
				color: var(--dark);
				font-family: "Manrope", system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
				-webkit-font-smoothing: antialiased;
			}
			main {
				max-width: 640px;
				padding: 48px 24px;
				text-align: center;
			}
			.logo {
				display: block;
				width: min(100%, 560px);
				height: auto;
				margin: 0 auto 24px;
			}
			.tagline {
				font-size: 20px;
				font-weight: 500;
				color: var(--dark);
				margin: 0 0 8px;
			}
			.subtagline {
				font-size: 16px;
				color: #6a6a6a;
				margin: 0 0 40px;
				line-height: 1.5;
			}
			.btn {
				display: inline-block;
				padding: 14px 32px;
				background: var(--gold);
				color: var(--light);
				text-decoration: none;
				border-radius: 4px;
				font-weight: 600;
				font-size: 15px;
				transition: background 0.2s;
			}
			.btn:hover { background: #967449; }
			footer {
				margin-top: 64px;
				font-size: 13px;
				color: #9a9a9a;
			}
		</style>
	</body>
</html>
