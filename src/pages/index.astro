---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroHome from "../components/HeroHome.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import BrandPrinciples from "../components/BrandPrinciples.astro";
import NumbersBlock from "../components/NumbersBlock.astro";
import DoctorsTeaser from "../components/DoctorsTeaser.astro";
import HomeFAQ from "../components/HomeFAQ.astro";
import CTA from "../components/CTA.astro";

const title = "Грета Орто — центр прозрачной ортодонтии в Санкт-Петербурге";
const description =
	"Лечение прикуса в Санкт-Петербурге: элайнеры, брекет-системы, гнатология и детская ортодонтия. Цифровой план до старта, фиксированная стоимость, бесплатная консультация.";
---

<BaseLayout title={title} description={description}>
	<HeroHome />
	<ServicesGrid />
	<BrandPrinciples />
	<NumbersBlock />
	<DoctorsTeaser />
	<HomeFAQ />

	<section class="final-cta-section">
		<div class="container">
			<CTA
				variant="wide"
				heading="Не уверены, что нужно вам — элайнеры или брекеты?"
				text="Это нормально. Мы для того и существуем, чтобы разобраться вместе. На бесплатной консультации врач делает 3D-сканирование и показывает оба варианта плана — выбираете вы."
				button="Записаться"
				secondaryButton="Позвонить +7 (812) 603-83-00"
				secondaryHref="tel:+78126038300"
			/>
		</div>
	</section>
</BaseLayout>

<style>
	.final-cta-section {
		padding: 0 0 var(--space-section);
	}
</style>
