---
import PillarLayout from "../../layouts/PillarLayout.astro";
import CTA from "../../components/CTA.astro";
import FAQ from "../../components/FAQ.astro";

const title = "Брекеты в Санкт-Петербурге — Грета Орто";
const description =
	"Установка брекетов в СПб: самолигирующие, керамические, лингвальные, металлические. Цены, сроки, рассрочка. Бесплатная консультация ортодонта.";

const faq = [
	{
		q: "Какие брекеты лучше поставить?",
		a: "Зависит от клинической задачи и приоритетов пациента: бюджет, эстетика, удобство, скорость. Самолигирующие сокращают визиты к врачу, керамические и лингвальные — менее заметны, металлические — самые доступные. Конкретный выбор делает ортодонт после диагностики.",
	},
	{
		q: "Сколько стоит установка брекетов в СПб?",
		a: "Зависит от типа системы и количества зубов, которые нужно перемещать. На бесплатной консультации мы фиксируем точную стоимость за весь курс лечения, включая контрольные визиты и активации.",
	},
	{
		q: "Сколько носят брекеты?",
		a: "В среднем — от 12 до 24 месяцев. После активной фазы обязателен ретенционный период с ретейнерами для удержания результата.",
	},
	{
		q: "Со скольки лет можно ставить брекеты?",
		a: "Несъёмные брекеты ставят после смены прикуса — обычно с 11–13 лет. До этого возраста используются пластинки, трейнеры и съёмные аппараты.",
	},
	{
		q: "Больно ли ставить брекеты?",
		a: "Сама установка — безболезненная процедура, занимает 1–1.5 часа. Первые 3–7 дней может ощущаться дискомфорт от давления — это норма, проходит самостоятельно.",
	},
];
---

<PillarLayout
	title={title}
	description={description}
	h1="Брекеты в Санкт-Петербурге"
	lead="Современные брекет-системы — от самолигирующих до лингвальных. Точная диагностика, фиксированная стоимость, контроль на каждом визите."
	breadcrumbs={[{ label: "Главная", href: "/" }, { label: "Брекеты" }]}
	procedureSchema={{
		name: "Лечение брекет-системами",
		description: "Ортодонтическое лечение с использованием несъёмных брекет-систем для выравнивания зубов и исправления прикуса.",
	}}
>
	<h2>Виды брекет-систем</h2>
	<ul>
		<li><a href="/brekety/vidy/samoligiruyushchie/">Самолигирующие</a> — с замочком вместо лигатуры, реже визиты</li>
		<li><a href="/brekety/vidy/keramicheskie/">Керамические</a> — менее заметны на зубах</li>
		<li><a href="/brekety/vidy/lingvalnye/">Лингвальные</a> — устанавливаются с внутренней стороны зубов</li>
		<li><a href="/brekety/vidy/ligaturnye/">Лигатурные металлические</a> — классика, доступная цена</li>
	</ul>

	<h2>Этапы лечения</h2>
	<p>
		Диагностика (фото, оттиски, КЛКТ при необходимости) → составление плана → установка → регулярные
		активации каждые 4–8 недель → снятие → ретенция. Всё фиксируется в карте, фото-сравнение прогресса
		ведётся на каждом визите.
	</p>

	<h2>Стоимость и рассрочка</h2>
	<p>
		Цена за весь курс — фиксированная, согласовывается на старте. Возможна рассрочка от клиники без
		банка и переплат. <a href="/brekety/cena/">Подробно про цену</a> и <a href="/brekety/spb/">цены по СПб</a>.
	</p>

	<h2>Бренды брекетов</h2>
	<ul>
		<li><a href="/brekety/brendy/damon-q/">Damon Q</a> — самолигирующие, премиум</li>
		<li><a href="/brekety/brendy/damon-q2/">Damon Q2</a> — обновлённая версия Damon</li>
		<li><a href="/brekety/brendy/damon-clear/">Damon Clear</a> — керамические самолигирующие</li>
		<li><a href="/brekety/brendy/incognito/">Incognito</a> — лингвальные, индивидуальное изготовление</li>
		<li><a href="/brekety/brendy/mini-diamond/">Mini Diamond</a> — компактные металлические</li>
	</ul>

	<h2>Полезное про лечение брекетами</h2>
	<ul>
		<li><a href="/brekety/uhod/">Уход за брекетами</a></li>
		<li><a href="/brekety/srok-nosheniya/">Сколько носят брекеты</a></li>
		<li><a href="/brekety/snyatie/">Снятие брекетов</a></li>
		<li><a href="/brekety/do-i-posle/">Брекеты до и после</a></li>
		<li><a href="/brekety/faq/">Частые вопросы (армия, МРТ, бесплатно и т.д.)</a></li>
	</ul>

	<CTA />

	<FAQ items={faq} />
</PillarLayout>
