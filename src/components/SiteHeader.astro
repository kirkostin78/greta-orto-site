---
const navItems = [
	{ href: "/elajnery/", label: "Элайнеры" },
	{ href: "/brekety/", label: "Брекеты" },
	{ href: "/prikus/", label: "Прикус" },
	{ href: "/ortodont/", label: "Врачи" },
	{ href: "/detskaya-ortodontiya/", label: "Детям" },
	{ href: "/gnatologiya/", label: "Гнатология" },
	{ href: "/klinika/", label: "Клиника" },
	{ href: "/kontakty/", label: "Контакты" },
];

const currentPath = new URL(Astro.request.url).pathname;
---

<header class="site-header">
	<a class="brand" href="/" aria-label="Грета Орто — на главную">
		<img src="/greta-orto-logo.png" alt="Грета Орто" width="280" height="60" />
	</a>
	<nav aria-label="Основная навигация">
		{
			navItems.map((item) => {
				const active = currentPath === item.href || currentPath.startsWith(item.href + "/");
				return (
					<a
						href={item.href}
						class:list={["nav-link", { active }]}
						aria-current={active ? "page" : undefined}
					>
						{item.label}
					</a>
				);
			})
		}
	</nav>
	<a class="btn-cta" href="/kontakty/">Записаться</a>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		display: flex;
		gap: 24px;
		align-items: center;
		justify-content: space-between;
		padding: 14px 24px;
		background: rgba(250, 250, 250, 0.95);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--grey);
	}

	.brand img {
		display: block;
		width: min(220px, 45vw);
		height: auto;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 6px 14px;
	}

	.nav-link {
		color: var(--dark);
		text-decoration: none;
		font-weight: 600;
		font-size: 14px;
		padding: 6px 4px;
		border-bottom: 2px solid transparent;
		transition: color 0.15s, border-color 0.15s;
	}

	.nav-link:hover {
		color: var(--gold);
	}

	.nav-link.active {
		color: var(--gold);
		border-bottom-color: var(--gold);
	}

	.btn-cta {
		display: inline-block;
		padding: 10px 18px;
		background: var(--gold);
		color: #fff;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 700;
		font-size: 14px;
		white-space: nowrap;
		transition: background 0.15s;
	}

	.btn-cta:hover {
		background: #967449;
	}

	@media (max-width: 1100px) {
		.site-header {
			flex-wrap: wrap;
		}

		nav {
			order: 3;
			width: 100%;
			justify-content: center;
			padding-top: 8px;
			border-top: 1px solid var(--grey);
		}
	}
</style>
