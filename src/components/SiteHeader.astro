---
import { siteLinks } from "../data/siteLinks";

const navItems = [
	{ href: "/elajnery/", label: "Элайнеры" },
	{ href: "/brekety/", label: "Брекеты" },
	{ href: "/prikus/", label: "Прикус" },
	{ href: "/detskaya-ortodontiya/", label: "Детям" },
	{ href: "/viniry/", label: "Виниры" },
	{ href: "/implantatsiya/", label: "Имплантация" },
	{ href: "/klinika/", label: "Клиника" },
	{ href: "/kontakty/", label: "Контакты" },
];

const phone = "+7 (812) 501-12-15";
const phoneTel = "+78125011215";

const currentPath = new URL(Astro.request.url).pathname;
---

<header class="site-header">
	<div class="header-inner">
		<a class="brand" href="/" aria-label="Грета Орто — на главную">
			<img
				class="brand-logo"
				src="/greta-orto-logo.svg"
				alt=""
				loading="eager"
				decoding="sync"
				width="1000"
				height="1000"
			/>
		</a>

		<a
			class="header-yandex"
			href={siteLinks.yandexOrg}
			target="_blank"
			rel="noopener"
		>
			<span class="header-yandex-stars" aria-hidden="true">5.0</span>
			<span class="header-yandex-text">Рейтинг 5.0 на Яндекс&nbsp;Картах</span>
		</a>

		<nav aria-label="Основная навигация" class="primary-nav">
			{
				navItems.map((item) => {
					const active = currentPath === item.href || currentPath.startsWith(item.href + "/");
					return (
						<a
							href={item.href}
							class:list={["nav-link", { active }]}
							aria-current={active ? "page" : undefined}
						>
							{item.label}
						</a>
					);
				})
			}
		</nav>

		<div class="header-cta">
			<div class="header-messengers" role="list" aria-label="Написать в мессенджер">
				<a
					class="msg-icon"
					href={siteLinks.telegram}
					target="_blank"
					rel="noopener"
					aria-label="Написать в Telegram"
					role="listitem"
					title="Telegram"
				>
					<svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
						<path
							fill="currentColor"
							d="M21.5 2.5 2.6 10.7c-1.7.7-1.7 1.7-.3 2.1l4.5 1.4 1.7 5.1c.2.6.1.8.6.8.4 0 .6-.2.9-.5l2.1-2.1 4.4 3.2c.8.4 1.3.2 1.5-.6l2.4-19.1c.2-1-1-1.6-1.7-1.2zM7.1 12.2l9.1-5.5c.4-.3.8 0 .4.4l-7.8 6.5-.1 2.1c.1.5-1-1-1-1L7.1 12.2z"
						></path>
					</svg>
				</a>
				<a
					class="msg-icon msg-icon--max"
					href={siteLinks.max}
					target="_blank"
					rel="noopener"
					aria-label="Написать в мессенджер MAX"
					role="listitem"
					title="MAX"
				>
					<img
						class="max-official-icon"
						src="/icons/max-messenger.svg"
						alt=""
						width="24"
						height="24"
						loading="eager"
						decoding="async"
					/>
				</a>
			</div>

			<a class="phone" href={`tel:${phoneTel}`} aria-label={`Позвонить ${phone}`}>
				<span class="phone-num">{phone}</span>
				<span class="phone-hint">Пн–Вс, 9:00–21:00</span>
			</a>

			<a class="header-online" href={siteLinks.onlineBooking} rel="noopener" target="_blank">
				<span class="header-online-ico" aria-hidden="true">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path
							d="M7 3h10a2 2 0 012 2v14l-2-1-2 1-2-1-2 1-2-1-2 1V5a2 2 0 012-2z"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linejoin="round"
						></path>
						<path
							d="M9 7h6M9 11h6M9 15h4"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
						></path>
					</svg>
				</span>
				<span class="header-online-text">
					<span class="header-online-title">Онлайн-запись</span>
					<span class="header-online-sub">врач и удобное время</span>
				</span>
			</a>

			<a class="btn-cta" href="/kontakty/">Контакты</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(255, 253, 250, 0.92);
		backdrop-filter: saturate(180%) blur(14px);
		-webkit-backdrop-filter: saturate(180%) blur(14px);
		border-bottom: 1px solid rgba(176, 138, 85, 0.12);
	}

	.header-inner {
		max-width: 1240px;
		margin: 0 auto;
		padding: 14px 24px;
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		grid-template-areas:
			"brand yandex cta"
			"nav nav cta";
		align-items: center;
		gap: 8px 20px;
	}

	.brand {
		grid-area: brand;
		display: inline-flex;
		align-items: center;
		text-decoration: none;
		flex-shrink: 0;
	}

	/**
	 * Логотип в SVG — квадрат 1:1 с полями; визуальный знак меньше квадрата.
	 * Высота больше плашки «Яндекс» (диск 36px + padding ~6+6), чтобы буквы читались не слабее соседнего блока.
	 */
	.brand-logo {
		display: block;
		flex-shrink: 0;
		height: clamp(108px, 12vw, 140px);
		width: auto;
		aspect-ratio: 1;
		object-fit: contain;
		object-position: left center;
	}

	.header-yandex {
		grid-area: yandex;
		display: inline-flex;
		align-items: center;
		gap: 8px;
		justify-self: start;
		text-decoration: none;
		color: var(--dark);
		border-radius: 10px;
		padding: 6px 10px 6px 4px;
		margin-left: -4px;
		border: 1px solid rgba(255, 193, 7, 0.35);
		background: linear-gradient(135deg, rgba(255, 248, 220, 0.9) 0%, rgba(255, 253, 250, 0.95) 100%);
		transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
		max-width: 100%;
	}

	.header-yandex:hover {
		border-color: rgba(176, 138, 85, 0.5);
		box-shadow: 0 4px 12px -6px rgba(0, 0, 0, 0.12);
	}

	.header-yandex-stars {
		flex-shrink: 0;
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: var(--gold);
		color: #fff;
		font-family: "Nunito", system-ui, sans-serif;
		font-weight: 800;
		font-size: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		line-height: 1;
	}

	.header-yandex-text {
		font-size: 12px;
		font-weight: 700;
		color: var(--ink);
		line-height: 1.25;
		letter-spacing: 0.01em;
	}

	.primary-nav {
		grid-area: nav;
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-start;
		gap: 4px 18px;
	}

	.nav-link {
		position: relative;
		color: var(--dark);
		text-decoration: none;
		font-weight: 600;
		font-size: 14px;
		padding: 6px 0;
		transition: color 0.2s;
	}

	.nav-link::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 2px;
		background: var(--gold);
		transform: scaleX(0);
		transform-origin: center;
		transition: transform 0.2s;
	}

	.nav-link:hover {
		color: var(--gold);
	}

	.nav-link:hover::after,
	.nav-link.active::after {
		transform: scaleX(1);
	}

	.nav-link.active {
		color: var(--gold);
	}

	.header-cta {
		grid-area: cta;
		display: flex;
		align-items: center;
		gap: 10px 12px;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.header-messengers {
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.msg-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 10px;
		color: #229ed9;
		background: rgba(34, 158, 217, 0.1);
		border: 1px solid rgba(34, 158, 217, 0.2);
		transition: background 0.2s, transform 0.15s, color 0.2s;
	}

	.msg-icon:hover {
		background: rgba(34, 158, 217, 0.2);
		transform: translateY(-1px);
	}

	.msg-icon--max {
		color: transparent;
		background: #fff;
		border-color: rgba(0, 0, 0, 0.08);
		padding: 0;
		overflow: hidden;
	}

	.msg-icon--max:hover {
		background: #f5f5f5;
		border-color: rgba(0, 0, 0, 0.12);
	}

	.max-official-icon {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.phone {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: var(--dark);
		text-align: right;
		line-height: 1.1;
	}

	.phone-num {
		font-family: "Nunito", system-ui, sans-serif;
		font-weight: 700;
		font-size: 16px;
		color: var(--dark);
	}

	.phone-hint {
		margin-top: 3px;
		font-size: 11px;
		color: var(--muted);
		letter-spacing: 0.4px;
	}

	.phone:hover .phone-num {
		color: var(--gold);
	}

	.header-online {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 8px 14px 8px 10px;
		border-radius: 12px;
		background: linear-gradient(145deg, #c9a45c 0%, #a77d3a 100%);
		color: #fff;
		text-decoration: none;
		font-weight: 800;
		box-shadow:
			0 0 0 1px rgba(255, 255, 255, 0.25) inset,
			0 8px 20px -8px rgba(100, 70, 20, 0.55);
		transition: transform 0.2s, box-shadow 0.2s, filter 0.2s;
		animation: headerOnlinePulse 3.5s ease-in-out infinite;
	}

	@keyframes headerOnlinePulse {
		0%,
		100% {
			box-shadow:
				0 0 0 1px rgba(255, 255, 255, 0.25) inset,
				0 8px 20px -8px rgba(100, 70, 20, 0.5);
		}
		50% {
			box-shadow:
				0 0 0 1px rgba(255, 255, 255, 0.35) inset,
				0 10px 24px -6px rgba(100, 70, 20, 0.65);
		}
	}

	.header-online:hover {
		filter: brightness(1.04);
		transform: translateY(-1px);
	}

	.header-online-ico {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		background: rgba(0, 0, 0, 0.12);
		border-radius: 8px;
	}

	.header-online-text {
		display: flex;
		flex-direction: column;
		gap: 0;
		line-height: 1.15;
	}

	.header-online-title {
		font-size: 13px;
		letter-spacing: 0.03em;
		font-family: "Nunito", system-ui, sans-serif;
	}

	.header-online-sub {
		font-size: 10.5px;
		font-weight: 600;
		opacity: 0.92;
		letter-spacing: 0.02em;
	}

	.btn-cta {
		display: inline-flex;
		align-items: center;
		padding: 11px 16px;
		background: #fff;
		color: var(--gold-dark);
		text-decoration: none;
		border-radius: 999px;
		font-weight: 700;
		font-size: 13px;
		letter-spacing: 0.2px;
		white-space: nowrap;
		border: 1px solid rgba(176, 138, 85, 0.45);
		transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
		box-shadow: 0 2px 8px -4px rgba(80, 60, 20, 0.25);
	}

	.btn-cta:hover {
		background: rgba(255, 250, 240, 0.95);
		transform: translateY(-1px);
		box-shadow: 0 4px 12px -4px rgba(100, 70, 20, 0.3);
	}

	@media (max-width: 1100px) {
		.header-yandex-text {
			font-size: 11px;
		}
	}

	@media (max-width: 1024px) {
		.header-inner {
			grid-template-columns: 1fr auto;
			grid-template-areas:
				"brand cta"
				"yandex yandex"
				"nav nav";
			gap: 10px 12px;
		}

		.brand-logo {
			height: clamp(96px, 18vw, 128px);
		}

		.header-yandex {
			justify-self: stretch;
		}

		.primary-nav {
			justify-content: flex-start;
			gap: 6px 18px;
			padding-top: 4px;
			border-top: 1px solid rgba(176, 138, 85, 0.12);
			overflow-x: auto;
			flex-wrap: nowrap;
			-webkit-overflow-scrolling: touch;
		}

		.nav-link {
			white-space: nowrap;
		}
	}

	@media (max-width: 900px) {
		.header-online-sub {
			display: none;
		}
		.header-online {
			padding: 8px 12px;
		}
	}

	@media (max-width: 720px) {
		.brand-logo {
			height: clamp(88px, 24vw, 120px);
		}

		.header-yandex {
			padding: 4px 8px 4px 4px;
		}
		.header-yandex-stars {
			width: 32px;
			height: 32px;
			font-size: 11px;
		}

		.phone-hint {
			display: none;
		}

		.phone-num {
			font-size: 14px;
		}

		.btn-cta {
			padding: 8px 12px;
			font-size: 12px;
		}
	}

	@media (max-width: 600px) {
		.header-cta {
			gap: 8px;
		}
		.header-messengers {
			order: 2;
		}
		.phone {
			order: 1;
		}
		.header-online {
			order: 0;
			width: 100%;
			justify-content: center;
		}
		.btn-cta {
			order: 3;
			width: 100%;
			justify-content: center;
		}
	}

	@media (max-width: 540px) {
		.phone {
			display: none;
		}
		.header-cta {
			gap: 6px 8px;
		}
		.header-messengers {
			order: 0;
		}
		.header-online {
			order: 1;
		}
		.btn-cta {
			order: 2;
			width: auto;
		}
	}
</style>
