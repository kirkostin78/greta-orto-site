---
const navItems = [
	{ href: "/elajnery/", label: "Элайнеры" },
	{ href: "/brekety/", label: "Брекеты" },
	{ href: "/prikus/", label: "Прикус" },
	{ href: "/detskaya-ortodontiya/", label: "Детям" },
	{ href: "/gnatologiya/", label: "Гнатология" },
	{ href: "/klinika/", label: "Клиника" },
	{ href: "/kontakty/", label: "Контакты" },
];

const phone = "+7 (812) 603-83-00";
const phoneTel = "+78126038300";

const currentPath = new URL(Astro.request.url).pathname;
---

<header class="site-header">
	<div class="header-inner">
		<a class="brand" href="/" aria-label="Грета Орто — на главную">
			<img
				src="/greta-orto-mark-header.png"
				srcset="/greta-orto-mark-header.png 1x, /greta-orto-mark-header@2x.png 2x"
				alt=""
				width="92"
				height="48"
				class="brand-mark"
				loading="eager"
				decoding="sync"
			/>
			<span class="brand-text">
				<span class="brand-name">Грета Орто</span>
				<span class="brand-tagline">центр прозрачной ортодонтии</span>
			</span>
		</a>

		<nav aria-label="Основная навигация" class="primary-nav">
			{
				navItems.map((item) => {
					const active = currentPath === item.href || currentPath.startsWith(item.href + "/");
					return (
						<a
							href={item.href}
							class:list={["nav-link", { active }]}
							aria-current={active ? "page" : undefined}
						>
							{item.label}
						</a>
					);
				})
			}
		</nav>

		<div class="header-cta">
			<a class="phone" href={`tel:${phoneTel}`} aria-label={`Позвонить ${phone}`}>
				<span class="phone-num">{phone}</span>
				<span class="phone-hint">Бесплатная консультация</span>
			</a>
			<a class="btn-cta" href="/kontakty/">Записаться</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(255, 253, 250, 0.92);
		backdrop-filter: saturate(180%) blur(14px);
		-webkit-backdrop-filter: saturate(180%) blur(14px);
		border-bottom: 1px solid rgba(176, 138, 85, 0.12);
	}

	.header-inner {
		max-width: 1240px;
		margin: 0 auto;
		padding: 14px 24px;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 28px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
	}

	.brand-mark {
		display: block;
		width: auto;
		height: 44px;
	}

	.brand-text {
		display: flex;
		flex-direction: column;
		line-height: 1;
	}

	.brand-name {
		font-family: "Nunito", system-ui, sans-serif;
		font-weight: 800;
		font-size: 22px;
		color: var(--gold);
		letter-spacing: -0.3px;
	}

	.brand-tagline {
		margin-top: 4px;
		font-size: 10.5px;
		color: var(--muted);
		letter-spacing: 0.8px;
		text-transform: uppercase;
	}

	.primary-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 4px 22px;
	}

	.nav-link {
		position: relative;
		color: var(--dark);
		text-decoration: none;
		font-weight: 600;
		font-size: 14px;
		padding: 6px 0;
		transition: color 0.2s;
	}

	.nav-link::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 2px;
		background: var(--gold);
		transform: scaleX(0);
		transform-origin: center;
		transition: transform 0.2s;
	}

	.nav-link:hover {
		color: var(--gold);
	}

	.nav-link:hover::after,
	.nav-link.active::after {
		transform: scaleX(1);
	}

	.nav-link.active {
		color: var(--gold);
	}

	.header-cta {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.phone {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: var(--dark);
		text-align: right;
		line-height: 1.1;
	}

	.phone-num {
		font-family: "Nunito", system-ui, sans-serif;
		font-weight: 700;
		font-size: 16px;
		color: var(--dark);
	}

	.phone-hint {
		margin-top: 3px;
		font-size: 11px;
		color: var(--muted);
		letter-spacing: 0.4px;
	}

	.phone:hover .phone-num {
		color: var(--gold);
	}

	.btn-cta {
		display: inline-flex;
		align-items: center;
		padding: 11px 20px;
		background: var(--gold);
		color: #fff;
		text-decoration: none;
		border-radius: 999px;
		font-weight: 700;
		font-size: 14px;
		letter-spacing: 0.2px;
		white-space: nowrap;
		transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
		box-shadow: 0 6px 16px -8px rgba(176, 138, 85, 0.55);
	}

	.btn-cta:hover {
		background: var(--gold-dark);
		transform: translateY(-1px);
		box-shadow: 0 10px 22px -10px rgba(176, 138, 85, 0.7);
	}

	@media (max-width: 1180px) {
		.brand-tagline {
			display: none;
		}
	}

	@media (max-width: 1024px) {
		.header-inner {
			grid-template-columns: auto 1fr;
			row-gap: 10px;
		}

		.primary-nav {
			grid-column: 1 / -1;
			order: 3;
			justify-content: flex-start;
			gap: 6px 18px;
			padding-top: 8px;
			border-top: 1px solid rgba(176, 138, 85, 0.12);
			overflow-x: auto;
			flex-wrap: nowrap;
			-webkit-overflow-scrolling: touch;
		}

		.nav-link {
			white-space: nowrap;
		}
	}

	@media (max-width: 720px) {
		.brand-mark {
			height: 36px;
		}

		.brand-name {
			font-size: 18px;
		}

		.phone-hint {
			display: none;
		}

		.phone-num {
			font-size: 14px;
		}

		.btn-cta {
			padding: 9px 14px;
			font-size: 13px;
		}
	}

	@media (max-width: 540px) {
		.phone {
			display: none;
		}

		.header-inner {
			gap: 12px;
		}
	}
</style>
