---
import MediaPlaceholder from "./MediaPlaceholder.astro";

const doctors = [
	{
		name: "Костина Дария Сергеевна",
		role: "Главный врач, ортодонт",
		specialties: ["Элайнеры", "Брекет-системы", "Детская ортодонтия"],
		experience: "22 года в стоматологии · 11 лет в ортодонтии",
		approach: "Ведёт сложные ортодонтические кейсы взрослых и детей. Лицо клиники по элайнерам.",
	},
	{
		name: "Костин Кирилл Александрович",
		role: "Главный врач клиники, стоматолог-ортопед",
		specialties: ["Виниры", "Коронки", "Протезирование"],
		experience: "Ведёт ортопедическое направление",
		approach: "Эстетическая ортопедия после ортодонтии: керамические виниры, коронки, реставрации.",
	},
	{
		name: "Борисова Анастасия Сергеевна",
		role: "Врач-ортодонт, гигиенист",
		specialties: ["Ортодонтия", "Гигиена"],
		experience: "Ведёт ортодонтических пациентов",
		approach: "Сопровождение лечения, профессиональная гигиена.",
	},
	{
		name: "Давыдова Юлия Радиевна",
		role: "Врач-ортодонт, гигиенист",
		specialties: ["Ортодонтия", "Гигиена"],
		experience: "Ведёт ортодонтических пациентов",
		approach: "Сопровождение лечения, профессиональная гигиена.",
	},
];

const initialsOf = (name) =>
	name
		.split(" ")
		.slice(0, 2)
		.map((p) => p[0])
		.join("");
---

<section class="doctors section section-warm">
	<div class="container">
		<div class="section-eyebrow">
			<span class="kicker">Врачи и команда</span>
			<h2>Кто ведёт ваше лечение</h2>
			<p>
				Один врач ведёт пациента от первой консультации до снятия ретейнера — без передачи между
				специалистами. Команда — главный ортодонт клиники, главврач-ортопед и два сопровождающих
				врача-ортодонта.
			</p>
		</div>

		<div class="doctors-grid">
			{
				doctors.map((d) => (
					<article class="doctor-card">
						<div class="doctor-photo">
							<MediaPlaceholder
								label={initialsOf(d.name)}
								hint="Портрет врача"
								aspect="square"
								rounded="md"
								tone="cream"
							/>
						</div>
						<div class="doctor-body">
							<h3>{d.name}</h3>
							<p class="doctor-role">{d.role}</p>
							<ul class="doctor-tags">
								{d.specialties.map((s) => (
									<li>{s}</li>
								))}
							</ul>
							<dl class="doctor-meta">
								<div>
									<dt>Опыт</dt>
									<dd>{d.experience}</dd>
								</div>
								<div>
									<dt>Подход</dt>
									<dd>{d.approach}</dd>
								</div>
							</dl>
						</div>
					</article>
				))
			}
		</div>

		<p class="doctors-cta">
			<a href="/ortodont/" class="btn btn-ghost">Подробно о врачах и подходе →</a>
		</p>
	</div>
</section>

<style>
	.doctors-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 20px;
	}

	.doctor-card {
		display: grid;
		grid-template-columns: 140px 1fr;
		gap: 22px;
		padding: 24px;
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius-md);
	}

	.doctor-photo {
		width: 140px;
	}

	.doctor-card h3 {
		margin: 0 0 4px;
		font-size: 18px;
		color: var(--ink);
		line-height: 1.3;
	}

	.doctor-role {
		margin: 0 0 12px;
		color: var(--gold-dark);
		font-size: 13.5px;
		font-weight: 600;
	}

	.doctor-tags {
		list-style: none;
		padding: 0;
		margin: 0 0 16px;
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.doctor-tags li {
		margin: 0;
		font-size: 12.5px;
		color: var(--muted);
		padding: 4px 10px;
		background: var(--cream);
		border-radius: var(--radius-pill);
		font-weight: 600;
	}

	.doctor-meta {
		margin: 0;
		display: grid;
		gap: 6px;
	}

	.doctor-meta div {
		display: grid;
		grid-template-columns: 70px 1fr;
		gap: 8px;
	}

	.doctor-meta dt {
		color: var(--muted);
		font-size: 12.5px;
	}

	.doctor-meta dd {
		margin: 0;
		font-size: 13px;
		color: var(--text);
		line-height: 1.5;
	}

	.doctors-cta {
		text-align: center;
		margin-top: 32px;
	}

	@media (max-width: 880px) {
		.doctors-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 540px) {
		.doctor-card {
			grid-template-columns: 1fr;
		}

		.doctor-photo {
			width: 100%;
			max-width: 200px;
		}

		.doctor-meta div {
			grid-template-columns: 1fr;
		}
	}
</style>
