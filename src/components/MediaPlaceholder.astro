---
interface Props {
	label?: string;
	hint?: string;
	aspect?: "square" | "portrait" | "landscape" | "wide" | "auto";
	rounded?: "sm" | "md" | "lg";
	tone?: "cream" | "soft" | "warm";
}

const {
	label = "Здесь будет фото",
	hint,
	aspect = "auto",
	rounded = "md",
	tone = "cream",
} = Astro.props;

const aspectMap = {
	square: "1 / 1",
	portrait: "3 / 4",
	landscape: "4 / 3",
	wide: "16 / 9",
	auto: "auto",
};

const roundedMap = {
	sm: "var(--radius-sm)",
	md: "var(--radius-md)",
	lg: "var(--radius-lg)",
};

const toneMap = {
	cream: "var(--cream)",
	soft: "var(--surface-soft)",
	warm: "var(--surface-warm)",
};
---

<div
	class="media-placeholder"
	style={`--ph-aspect: ${aspectMap[aspect]}; --ph-radius: ${roundedMap[rounded]}; --ph-bg: ${toneMap[tone]};`}
	aria-label={label}
>
	<div class="ph-inner">
		<svg class="ph-icon" viewBox="0 0 48 48" fill="none" aria-hidden="true">
			<rect x="6" y="10" width="36" height="28" rx="3" stroke="currentColor" stroke-width="1.5" />
			<circle cx="17" cy="20" r="3" stroke="currentColor" stroke-width="1.5" />
			<path
				d="M8 36L19 25L26 31L33 24L40 30"
				stroke="currentColor"
				stroke-width="1.5"
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
		</svg>
		<div class="ph-label">{label}</div>
		{hint && <div class="ph-hint">{hint}</div>}
	</div>
</div>

<style>
	.media-placeholder {
		width: 100%;
		aspect-ratio: var(--ph-aspect);
		background: var(--ph-bg);
		border: 1px dashed var(--line-strong);
		border-radius: var(--ph-radius);
		display: grid;
		place-items: center;
		overflow: hidden;
		position: relative;
	}

	.media-placeholder::before {
		content: "";
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(45deg, transparent 48%, rgba(176, 138, 85, 0.08) 49%, rgba(176, 138, 85, 0.08) 51%, transparent 52%);
		background-size: 22px 22px;
		opacity: 0.5;
		pointer-events: none;
	}

	.ph-inner {
		position: relative;
		z-index: 1;
		text-align: center;
		padding: 24px;
		max-width: 80%;
	}

	.ph-icon {
		width: 44px;
		height: 44px;
		color: var(--gold);
		opacity: 0.55;
		margin-bottom: 12px;
	}

	.ph-label {
		font-family: "Nunito", sans-serif;
		font-weight: 700;
		font-size: 14px;
		color: var(--gold-dark);
		letter-spacing: 0.3px;
	}

	.ph-hint {
		margin-top: 6px;
		font-size: 12.5px;
		color: var(--muted);
		line-height: 1.4;
	}
</style>
