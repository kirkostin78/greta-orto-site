---
const numbers = [
	{ value: "22", label: "года в стоматологии", note: "опыт ведущего ортодонта Д. С. Костиной" },
	{ value: "11", label: "лет в ортодонтии", note: "специализация на элайнерах и сложных кейсах" },
	{ value: "7/7", label: "дней в неделю", note: "9:00–21:00, без выходных" },
	{ value: "8+", label: "лет — детям", note: "ортодонтия для детей и подростков" },
];
---

<section class="numbers section">
	<div class="container">
		<div class="numbers-grid">
			{
				numbers.map((n) => (
					<div class="number">
						<div class="number-value">{n.value}</div>
						<div class="number-label">{n.label}</div>
						<div class="number-note">{n.note}</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.numbers-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 8px;
		padding: 40px 32px;
		background: var(--cream);
		border-radius: var(--radius-lg);
		position: relative;
		overflow: hidden;
	}

	.numbers-grid::before {
		content: "";
		position: absolute;
		top: -40%;
		right: -10%;
		width: 60%;
		height: 180%;
		background: radial-gradient(closest-side, rgba(255, 255, 255, 0.5), transparent);
		pointer-events: none;
	}

	.number {
		position: relative;
		text-align: center;
		padding: 8px 12px;
	}

	.number + .number {
		border-left: 1px solid rgba(176, 138, 85, 0.2);
	}

	.number-value {
		font-family: "Nunito", sans-serif;
		font-weight: 800;
		font-size: clamp(32px, 4vw, 44px);
		color: var(--gold-dark);
		line-height: 1;
		letter-spacing: -0.02em;
	}

	.number-label {
		margin-top: 8px;
		font-size: 14.5px;
		font-weight: 700;
		color: var(--ink);
	}

	.number-note {
		margin-top: 4px;
		font-size: 12.5px;
		color: var(--muted);
		letter-spacing: 0.2px;
	}

	@media (max-width: 720px) {
		.number + .number {
			border-left: none;
			border-top: 1px solid rgba(176, 138, 85, 0.2);
			padding-top: 18px;
			margin-top: 10px;
		}
	}
</style>
