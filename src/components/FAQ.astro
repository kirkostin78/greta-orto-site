---
interface QA {
	q: string;
	a: string;
}

interface Props {
	heading?: string;
	items: QA[];
	emitSchema?: boolean;
}

const { heading = "Частые вопросы", items, emitSchema = true } = Astro.props as Props;

const jsonLd = emitSchema
	? {
			"@context": "https://schema.org",
			"@type": "FAQPage",
			mainEntity: items.map((it) => ({
				"@type": "Question",
				name: it.q,
				acceptedAnswer: {
					"@type": "Answer",
					text: it.a,
				},
			})),
		}
	: null;
---

<section class="faq">
	<h2>{heading}</h2>
	<dl>
		{
			items.map((it) => (
				<details>
					<summary>{it.q}</summary>
					<div class="answer" set:html={it.a} />
				</details>
			))
		}
	</dl>
</section>

{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

<style>
	.faq {
		margin: 40px 0;
	}

	.faq dl {
		display: grid;
		gap: 8px;
		margin: 0;
	}

	details {
		background: #fff;
		border: 1px solid var(--grey);
		border-radius: 10px;
		padding: 0;
	}

	details[open] {
		border-color: var(--gold);
	}

	summary {
		padding: 16px 20px;
		font-weight: 600;
		font-size: 16px;
		cursor: pointer;
		list-style: none;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 16px;
	}

	summary::-webkit-details-marker {
		display: none;
	}

	summary::after {
		content: "+";
		font-size: 22px;
		color: var(--gold);
		font-weight: 400;
		transition: transform 0.15s;
	}

	details[open] summary::after {
		content: "−";
	}

	.answer {
		padding: 0 20px 18px;
		color: #4a4a4a;
		line-height: 1.6;
	}
</style>
