---
interface Props {
	heading?: string;
	text?: string;
	button?: string;
	href?: string;
	variant?: "default" | "compact" | "wide";
	secondaryButton?: string;
	secondaryHref?: string;
}

const {
	heading = "Запишитесь на бесплатную консультацию",
	text = "Врач-ортодонт проведёт диагностику, ответит на вопросы и составит цифровой план лечения. Длительность приёма — 40–60 минут.",
	button = "Записаться на консультацию",
	href = "/kontakty/",
	variant = "default",
	secondaryButton,
	secondaryHref,
} = Astro.props as Props;
---

<aside class:list={["cta", variant]}>
	<div class="cta-text">
		<h3>{heading}</h3>
		<p>{text}</p>
	</div>
	<div class="cta-actions">
		<a class="btn" href={href}>{button}</a>
		{secondaryButton && secondaryHref && (
			<a class="btn btn-ghost" href={secondaryHref}>{secondaryButton}</a>
		)}
	</div>
</aside>

<style>
	.cta {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: center;
		gap: 28px;
		padding: 36px 40px;
		margin: 32px 0;
		background:
			radial-gradient(800px 400px at 100% 0%, rgba(176, 138, 85, 0.18), transparent 60%),
			linear-gradient(135deg, var(--cream) 0%, var(--cream-deep) 100%);
		border-radius: var(--radius-lg);
		border: 1px solid var(--line-strong);
	}

	.cta.compact {
		padding: 22px 26px;
		margin: 18px 0;
	}

	.cta.wide {
		padding: 48px 48px;
	}

	.cta h3 {
		margin: 0 0 8px;
		font-family: "Nunito", system-ui, sans-serif;
		font-size: clamp(20px, 2.4vw, 26px);
		color: var(--ink);
	}

	.cta p {
		margin: 0;
		color: var(--muted);
		font-size: 15px;
		line-height: 1.55;
		max-width: 50ch;
	}

	.cta-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	@media (max-width: 720px) {
		.cta,
		.cta.compact,
		.cta.wide {
			grid-template-columns: 1fr;
			padding: 28px 26px;
		}

		.cta-actions {
			flex-direction: column;
			align-items: stretch;
		}

		.cta .btn {
			width: 100%;
			text-align: center;
		}
	}
</style>
