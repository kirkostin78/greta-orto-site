---
interface Props {
	heading?: string;
	text?: string;
	button?: string;
	href?: string;
	variant?: "default" | "compact";
}

const {
	heading = "Запишитесь на консультацию",
	text = "На приёме врач-ортодонт оценит прикус, ответит на вопросы и подберёт оптимальный план лечения.",
	button = "Записаться на консультацию",
	href = "/kontakty/",
	variant = "default",
} = Astro.props as Props;
---

<aside class:list={["cta", variant]}>
	<div class="cta-text">
		<h3>{heading}</h3>
		<p>{text}</p>
	</div>
	<a class="btn" href={href}>{button}</a>
</aside>

<style>
	.cta {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: center;
		gap: 24px;
		padding: 28px 32px;
		margin: 32px 0;
		background: linear-gradient(135deg, #f7eee0, #efe2c9);
		border-radius: 14px;
		border: 1px solid #e7d6b4;
	}

	.cta.compact {
		padding: 18px 22px;
		margin: 18px 0;
		grid-template-columns: 1fr auto;
	}

	.cta h3 {
		margin: 0 0 6px;
		font-family: "Nunito", system-ui, sans-serif;
		font-size: 20px;
		color: var(--dark);
	}

	.cta p {
		margin: 0;
		color: #5b4f3a;
		font-size: 14px;
		line-height: 1.45;
	}

	.cta .btn {
		display: inline-block;
		padding: 12px 22px;
		background: var(--gold);
		color: #fff;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 700;
		font-size: 15px;
		white-space: nowrap;
		transition: background 0.15s;
	}

	.cta .btn:hover {
		background: #967449;
	}

	@media (max-width: 600px) {
		.cta,
		.cta.compact {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.cta .btn {
			justify-self: stretch;
			text-align: center;
		}
	}
</style>
