---
const ratings = [
	{ source: "Яндекс Карты", value: "—", note: "Откроем после индексации" },
	{ source: "ProDoctorov", value: "—", note: "Профиль готовится" },
	{ source: "НаПоправку", value: "—", note: "Профиль готовится" },
	{ source: "Google Maps", value: "—", note: "Профиль готовится" },
];

const reviews = [
	{
		text: "Объективные и достоверные отзывы пациентов мы публикуем только после согласования с ними. Сейчас собираем первые отзывы — раздел будет наполнен в ближайшие недели.",
		author: "Раздел в подготовке",
		role: "",
	},
];
---

<section class="reviews section">
	<div class="container">
		<div class="section-eyebrow">
			<span class="kicker">Отзывы и рейтинги</span>
			<h2>Что говорят о клинике</h2>
			<p>
				Мы не покупаем отзывы и не показываем фейковые рейтинги. Реальные оценки появятся
				на независимых площадках по мере накопления реальных пациентских отзывов.
			</p>
		</div>

		<div class="reviews-ratings">
			{
				ratings.map((r) => (
					<div class="rating-card">
						<div class="rating-value">{r.value}</div>
						<div class="rating-source">{r.source}</div>
						<div class="rating-note">{r.note}</div>
					</div>
				))
			}
		</div>

		<div class="reviews-placeholder">
			<svg viewBox="0 0 32 32" fill="none" aria-hidden="true">
				<path
					d="M6 8h20v14H10l-4 4V8z"
					stroke="currentColor"
					stroke-width="1.6"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
				<circle cx="12" cy="15" r="1" fill="currentColor" />
				<circle cx="16" cy="15" r="1" fill="currentColor" />
				<circle cx="20" cy="15" r="1" fill="currentColor" />
			</svg>
			<p>{reviews[0].text}</p>
			<span class="reviews-placeholder-author">{reviews[0].author}</span>
		</div>
	</div>
</section>

<style>
	.reviews-ratings {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 14px;
		margin-bottom: 32px;
	}

	.rating-card {
		text-align: center;
		padding: 22px 16px;
		background: var(--surface-soft);
		border: 1px solid var(--line);
		border-radius: var(--radius-md);
	}

	.rating-value {
		font-family: "Nunito", sans-serif;
		font-weight: 800;
		font-size: 28px;
		color: var(--gold-dark);
		line-height: 1;
		margin-bottom: 8px;
	}

	.rating-source {
		font-size: 14px;
		font-weight: 700;
		color: var(--ink);
		margin-bottom: 4px;
	}

	.rating-note {
		font-size: 12px;
		color: var(--muted);
		font-style: italic;
	}

	.reviews-placeholder {
		max-width: 640px;
		margin: 0 auto;
		text-align: center;
		padding: 32px 28px;
		background: var(--surface);
		border: 1px dashed var(--line-strong);
		border-radius: var(--radius-md);
	}

	.reviews-placeholder svg {
		width: 36px;
		height: 36px;
		color: var(--gold-soft);
		margin-bottom: 12px;
	}

	.reviews-placeholder p {
		margin: 0 0 12px;
		color: var(--muted);
		font-size: 15px;
		line-height: 1.6;
	}

	.reviews-placeholder-author {
		font-size: 12px;
		color: var(--gold-dark);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	@media (max-width: 720px) {
		.reviews-ratings {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 420px) {
		.reviews-ratings {
			grid-template-columns: 1fr;
		}
	}
</style>
