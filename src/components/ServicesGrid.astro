---
const focusServices = [
	{
		href: "/elajnery/",
		title: "Элайнеры",
		text: "Прозрачные капы. Незаметно для окружающих, можно снимать на еду и чистку зубов. Главный продукт клиники — лечим самые сложные случаи.",
		hint: "Главный фокус · Лидер по СПб",
		featured: true,
	},
	{
		href: "/brekety/",
		title: "Брекет-системы",
		text: "Самолигирующие, керамические, металлические — выбор по клинической задаче, когда элайнеры уступают по эффективности.",
		hint: "От 1.5 лет · Сложные случаи",
	},
	{
		href: "/prikus/",
		title: "Исправление прикуса",
		text: "Дистальный, мезиальный, глубокий, перекрёстный, открытый — диагностика, план и решение.",
		hint: "Любой возраст",
	},
	{
		href: "/detskaya-ortodontiya/",
		title: "Детская ортодонтия",
		text: "Пластинки, трейнеры, элайнеры и брекеты для детей и подростков. Принимаем с 8 лет.",
		hint: "От 8 лет",
	},
	{
		href: "/gnatologiya/",
		title: "Гнатология / ВНЧС",
		text: "Дисфункция височно-нижнечелюстного сустава, бруксизм, головные боли от прикуса.",
		hint: "Диагностика и сплинт-терапия",
	},
	{
		href: "/retentsiya/",
		title: "Ретенция",
		text: "Удержание результата после активного лечения: ретейнеры, ретенционные капы, контроль.",
		hint: "Завершающий этап",
	},
];

const additionalServices = [
	{
		href: "/viniry/",
		title: "Виниры",
		text: "Эстетическая ортопедия после ортодонтического лечения. Керамические виниры, накладки, реставрации.",
		hint: "Дополнительная экспертиза",
	},
	{
		href: "/implantatsiya/",
		title: "Имплантация",
		text: "Восстановление отсутствующих зубов. Подготовка с ортодонтом — там, где это даёт лучший результат.",
		hint: "Дополнительная экспертиза",
	},
];
---

<section class="services section">
	<div class="container">
		<div class="section-eyebrow">
			<span class="kicker">Что мы делаем</span>
			<h2>Главный фокус — ортодонтия. Глубокая экспертиза в виниринге и имплантации.</h2>
			<p>
				Лечение на элайнерах — наш профильный продукт, в нём мы сильнее всех в Санкт-Петербурге.
				Дополнительно ведём виниры и имплантацию — для пациентов, которым нужен комплексный
				результат после ортодонтии.
			</p>
		</div>

		<div class="services-grid">
			{
				focusServices.map((s) => (
					<a class:list={["service-card", { featured: s.featured }]} href={s.href}>
						<div class="service-card-top">
							<h3>{s.title}</h3>
							<span class="service-arrow" aria-hidden="true">
								→
							</span>
						</div>
						<p>{s.text}</p>
						<span class="service-hint">{s.hint}</span>
					</a>
				))
			}
		</div>

		<div class="services-additional">
			<div class="services-additional-label">Также делаем</div>
			<div class="services-grid">
				{
					additionalServices.map((s) => (
						<a class="service-card additional" href={s.href}>
							<div class="service-card-top">
								<h3>{s.title}</h3>
								<span class="service-arrow" aria-hidden="true">
									→
								</span>
							</div>
							<p>{s.text}</p>
							<span class="service-hint">{s.hint}</span>
						</a>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 16px;
	}

	.service-card {
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding: 28px 26px;
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius-md);
		text-decoration: none;
		color: var(--text);
		transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
	}

	.service-card.featured {
		background: linear-gradient(135deg, var(--cream) 0%, var(--surface) 100%);
		border-color: var(--gold-soft);
	}

	.service-card.additional {
		background: var(--surface-soft);
		border-style: dashed;
	}

	.service-card:hover {
		border-color: var(--gold-soft);
		border-style: solid;
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
		color: var(--text);
	}

	.service-card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.service-card h3 {
		margin: 0;
		color: var(--ink);
		font-size: 21px;
	}

	.service-arrow {
		font-size: 20px;
		color: var(--gold);
		transition: transform 0.2s;
	}

	.service-card:hover .service-arrow {
		transform: translateX(4px);
	}

	.service-card p {
		margin: 0;
		color: var(--muted);
		font-size: 15px;
		line-height: 1.55;
	}

	.service-hint {
		margin-top: auto;
		padding-top: 12px;
		border-top: 1px solid var(--line);
		font-size: 12.5px;
		color: var(--muted-soft);
		letter-spacing: 0.3px;
		text-transform: uppercase;
		font-weight: 600;
	}

	.service-card.featured .service-hint {
		color: var(--gold-dark);
	}

	.services-additional {
		margin-top: 40px;
	}

	.services-additional-label {
		font-size: 13px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1.2px;
		color: var(--muted);
		margin-bottom: 14px;
	}

	.services-additional .services-grid {
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
	}
</style>
