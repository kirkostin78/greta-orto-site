---
const services = [
	{
		href: "/elajnery/",
		title: "Элайнеры",
		text: "Прозрачные капы. Незаметно для окружающих, можно снимать на еду и чистку зубов.",
		hint: "От 1 года · Подходит большинству",
	},
	{
		href: "/brekety/",
		title: "Брекет-системы",
		text: "Самолигирующие, керамические, лингвальные и металлические — выбор по клинической задаче.",
		hint: "От 1.5 лет · Сложные случаи",
	},
	{
		href: "/prikus/",
		title: "Исправление прикуса",
		text: "Дистальный, мезиальный, глубокий, перекрёстный, открытый — диагностика и план.",
		hint: "Любой возраст",
	},
	{
		href: "/detskaya-ortodontiya/",
		title: "Детская ортодонтия",
		text: "Пластинки, трейнеры, элайнеры и брекеты для детей и подростков. Профилактика и коррекция.",
		hint: "От 4 лет",
	},
	{
		href: "/gnatologiya/",
		title: "Гнатология / ВНЧС",
		text: "Дисфункция височно-нижнечелюстного сустава, бруксизм, головные боли от прикуса.",
		hint: "Диагностика и сплинт-терапия",
	},
	{
		href: "/retentsiya/",
		title: "Ретенция",
		text: "Удержание результата после активного лечения: ретейнеры, ретенционные капы, контроль.",
		hint: "Завершающий этап",
	},
];
---

<section class="services section">
	<div class="container">
		<div class="section-eyebrow">
			<span class="kicker">Что мы лечим</span>
			<h2>Полный цикл ортодонтии — от первого визита до ретенции</h2>
			<p>
				В клинике мы занимаемся только ортодонтией и смежными темами. Без распыления — поэтому глубокая
				экспертиза в каждом направлении.
			</p>
		</div>

		<div class="services-grid">
			{
				services.map((s) => (
					<a class="service-card" href={s.href}>
						<div class="service-card-top">
							<h3>{s.title}</h3>
							<span class="service-arrow" aria-hidden="true">
								→
							</span>
						</div>
						<p>{s.text}</p>
						<span class="service-hint">{s.hint}</span>
					</a>
				))
			}
		</div>
	</div>
</section>

<style>
	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 16px;
	}

	.service-card {
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding: 28px 26px;
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius-md);
		text-decoration: none;
		color: var(--text);
		transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
	}

	.service-card:hover {
		border-color: var(--gold-soft);
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
		color: var(--text);
	}

	.service-card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.service-card h3 {
		margin: 0;
		color: var(--ink);
		font-size: 21px;
	}

	.service-arrow {
		font-size: 20px;
		color: var(--gold);
		transition: transform 0.2s;
	}

	.service-card:hover .service-arrow {
		transform: translateX(4px);
	}

	.service-card p {
		margin: 0;
		color: var(--muted);
		font-size: 15px;
		line-height: 1.55;
	}

	.service-hint {
		margin-top: auto;
		padding-top: 12px;
		border-top: 1px solid var(--line);
		font-size: 12.5px;
		color: var(--muted-soft);
		letter-spacing: 0.3px;
		text-transform: uppercase;
		font-weight: 600;
	}
</style>
