---
import { galleryPhotos } from "../data/homeMedia";
---

<section class="gallery section section-soft">
	<div class="container">
		<div class="section-eyebrow">
			<span class="kicker">Интерьеры клиники</span>
			<h2>Внутри клиники</h2>
			<p>ул. Марата, 68. Хорошо добраться от метро Маяковская и Владимирская.</p>
		</div>

		<div class="gallery-grid">
			{
				galleryPhotos.map((g, i) => (
					<div class:list={["gallery-item", `gallery-item-${i + 1}`]}>
						<div class="gallery-img-wrap">
							<img
								class="gallery-img"
								src={g.src}
								alt={g.alt}
								width="1200"
								height="900"
								loading="lazy"
								decoding="async"
							/>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.gallery-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		grid-template-rows: auto auto;
		gap: 12px;
	}

	.gallery-item-1 {
		grid-column: 1;
		grid-row: 1 / 3;
	}

	.gallery-item-1 .gallery-img-wrap {
		aspect-ratio: 3 / 4;
	}

	.gallery-item-2 {
		grid-column: 2;
		grid-row: 1;
	}

	.gallery-item-3 {
		grid-column: 3;
		grid-row: 1 / 3;
	}

	.gallery-item-3 .gallery-img-wrap {
		aspect-ratio: 3 / 5;
	}

	.gallery-item-4 {
		grid-column: 2;
		grid-row: 2;
	}

	.gallery-item-5 {
		display: none;
	}

	.gallery-img-wrap {
		width: 100%;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--cream);
		border: 1px solid var(--line);
	}

	.gallery-item-2 .gallery-img-wrap,
	.gallery-item-4 .gallery-img-wrap {
		aspect-ratio: 4 / 3;
	}

	.gallery-img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	@media (max-width: 880px) {
		.gallery-grid {
			grid-template-columns: 1fr 1fr;
			grid-template-rows: auto;
		}

		.gallery-item-1,
		.gallery-item-2,
		.gallery-item-3,
		.gallery-item-4,
		.gallery-item-5 {
			grid-column: auto;
			grid-row: auto;
		}

		.gallery-item-1 .gallery-img-wrap,
		.gallery-item-3 .gallery-img-wrap {
			aspect-ratio: 4 / 3;
		}

		.gallery-item-5 {
			display: block;
		}
	}

	@media (max-width: 540px) {
		.gallery-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
