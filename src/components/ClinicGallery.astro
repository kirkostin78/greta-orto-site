---
import MediaPlaceholder from "./MediaPlaceholder.astro";

const slots = [
	{ label: "Ресепшен", hint: "Зона ожидания, тёплый свет", aspect: "landscape" },
	{ label: "Кабинет ортодонта", hint: "Главный кабинет Костиной Д. С.", aspect: "landscape" },
	{ label: "Зона диагностики", hint: "КЛКТ + 3D-сканер", aspect: "portrait" },
	{ label: "Кабинет хирургии", hint: "Имплантация, удаление", aspect: "landscape" },
	{ label: "Коридор", hint: "Общий вид клиники", aspect: "landscape" },
];
---

<section class="gallery section section-soft">
	<div class="container">
		<div class="section-eyebrow">
			<span class="kicker">Интерьеры клиники</span>
			<h2>Внутри клиники</h2>
			<p>ул. Марата, 68. Хорошо добраться от метро Маяковская и Владимирская.</p>
		</div>

		<div class="gallery-grid">
			{
				slots.map((s, i) => (
					<div class:list={["gallery-item", `gallery-item-${i + 1}`]}>
						<MediaPlaceholder
							label={s.label}
							hint={s.hint}
							aspect={s.aspect}
							rounded="md"
							tone="cream"
						/>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.gallery-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		grid-template-rows: auto auto;
		gap: 12px;
	}

	.gallery-item-1 {
		grid-column: 1;
		grid-row: 1 / 3;
	}

	.gallery-item-2 {
		grid-column: 2;
		grid-row: 1;
	}

	.gallery-item-3 {
		grid-column: 3;
		grid-row: 1 / 3;
	}

	.gallery-item-4 {
		grid-column: 2;
		grid-row: 2;
	}

	.gallery-item-5 {
		display: none;
	}

	@media (max-width: 880px) {
		.gallery-grid {
			grid-template-columns: 1fr 1fr;
			grid-template-rows: auto;
		}

		.gallery-item-1,
		.gallery-item-2,
		.gallery-item-3,
		.gallery-item-4,
		.gallery-item-5 {
			grid-column: auto;
			grid-row: auto;
		}

		.gallery-item-5 {
			display: block;
		}
	}

	@media (max-width: 540px) {
		.gallery-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
