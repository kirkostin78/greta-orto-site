---
import { techPhotos } from "../data/homeMedia";

const techs = [
	{
		title: "КЛКТ обеих челюстей",
		text: "Свой аппарат компьютерной томографии в клинике. Не отправляем пациентов делать снимки в сторонние центры — делаем здесь и сразу.",
		...techPhotos[0],
	},
	{
		title: "3D-сканер",
		text: "Цифровые оттиски без слепочной массы. Сканирование занимает 10–15 минут, данные сразу идут в орточек-план лечения.",
		...techPhotos[1],
	},
	{
		title: "Орточек (Digital Setup)",
		text: "Цифровое моделирование лечения. Видите финальный результат и каждый этап до старта — не на словах, а в 3D на экране.",
		...techPhotos[2],
	},
	{
		title: "Микроскоп",
		text: "Для эндодонтии и сложных терапевтических работ. Точность реставраций на порядок выше, чем без микроскопа.",
		...techPhotos[3],
	},
];
---

<section class="tech section">
	<div class="container">
		<div class="section-eyebrow">
			<span class="kicker">Технологии и оборудование</span>
			<h2>Всё для диагностики и лечения — на месте</h2>
			<p>
				Это не маркетинг. Когда у клиники свой КЛКТ и 3D-сканер, пациент получает диагностику в один
				день, а врач — точные данные для планирования лечения.
			</p>
		</div>

		<div class="tech-grid">
			{
				techs.map((t) => (
					<article class="tech-card">
						<div class="tech-media">
							<div class="tech-img-wrap">
								<img
									class="tech-img"
									src={t.src}
									alt={t.alt}
									width="800"
									height="600"
									loading="lazy"
									decoding="async"
								/>
							</div>
						</div>
						<div class="tech-body">
							<h3>{t.title}</h3>
							<p>{t.text}</p>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.tech-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 24px 32px;
	}

	.tech-card {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: 20px;
		align-items: start;
	}

	.tech-media {
		width: 200px;
	}

	.tech-img-wrap {
		aspect-ratio: 4 / 3;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--surface-soft);
		border: 1px solid var(--line);
	}

	.tech-img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.tech-body h3 {
		margin: 4px 0 8px;
		font-size: 18px;
		color: var(--ink);
	}

	.tech-body p {
		margin: 0;
		color: var(--muted);
		font-size: 14.5px;
		line-height: 1.55;
	}

	@media (max-width: 880px) {
		.tech-grid {
			grid-template-columns: 1fr;
			gap: 24px;
		}
	}

	@media (max-width: 540px) {
		.tech-card {
			grid-template-columns: 1fr;
		}

		.tech-media {
			width: 100%;
			max-width: 360px;
		}
	}
</style>
