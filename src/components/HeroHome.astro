---
import { homeHero } from "../data/homeMedia";

const phone = "+7 (812) 501-12-15";
const phoneTel = "+78125011215";
---

<section class="hero">
	<div class="container">
		<div class="hero-grid">
			<div class="hero-copy">
				<span class="kicker">Центр прозрачной ортодонтии · Санкт-Петербург</span>
				<h1>
					Лечение прикуса, <br />
					которое можно увидеть <span class="accent">до начала</span>
				</h1>
				<p class="lead">
					Главный фокус — лечение на элайнерах. Также делаем брекет-системы, виниры и имплантацию,
					когда нужны комплексные решения. Перед стартом вы видите цифровой план лечения и фиксированную
					стоимость до конца курса.
				</p>

				<ul class="hero-points" aria-label="Что вы получаете">
					<li><span aria-hidden="true">·</span> 3D-план лечения до старта (орточек)</li>
					<li><span aria-hidden="true">·</span> Фиксированная стоимость на весь курс</li>
					<li><span aria-hidden="true">·</span> Один врач ведёт от консультации до ретейнера</li>
				</ul>

				<div class="hero-cta">
					<a class="btn" href="/kontakty/">Записаться на консультацию</a>
					<a class="btn btn-ghost" href="/elajnery/">Узнать про элайнеры</a>
				</div>

				<a class="hero-phone" href={`tel:${phoneTel}`}>
					<span class="hero-phone-num">{phone}</span>
					<span class="hero-phone-hint">Пн–Вс, 9:00–21:00 · ул. Марата, 68</span>
				</a>
			</div>

			<aside class="hero-side">
				<div class="hero-media">
					<img
						class="hero-img"
						src={homeHero.src}
						alt={homeHero.alt}
						width="800"
						height="1067"
						loading="eager"
						fetchpriority="high"
					/>
				</div>

				<div class="hero-promo" role="note">
					<div class="hero-promo-row">
						<svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.6" />
							<path
								d="M8 12.5L11 15L16 9.5"
								stroke="currentColor"
								stroke-width="1.8"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
						<div>
							<strong>КЛКТ обеих челюстей в подарок</strong>
							<span>при старте лечения у нас (после первичной консультации)</span>
						</div>
					</div>
				</div>
			</aside>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		padding: clamp(20px, 3.5vw, 48px) 0 clamp(48px, 7vw, 88px);
		background:
			radial-gradient(1100px 520px at 90% -10%, rgba(176, 138, 85, 0.12), transparent 60%),
			radial-gradient(900px 600px at 0% 100%, rgba(247, 238, 224, 0.85), transparent 65%),
			var(--surface);
		overflow: hidden;
	}

	.hero::before {
		content: "";
		position: absolute;
		inset: auto 0 0 0;
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--line-strong), transparent);
		opacity: 0.7;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
		gap: clamp(32px, 5vw, 64px);
		align-items: center;
	}

	.hero-copy h1 {
		margin-bottom: 18px;
	}

	.hero-copy h1 .accent {
		color: var(--gold-dark);
		font-style: italic;
		font-weight: 700;
	}

	.hero-points {
		list-style: none;
		padding: 0;
		margin: 24px 0 0;
		display: grid;
		gap: 8px;
	}

	.hero-points li {
		font-size: 16px;
		color: var(--text);
		display: flex;
		gap: 10px;
		align-items: baseline;
	}

	.hero-points li span {
		color: var(--gold);
		font-weight: 800;
	}

	.hero-cta {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.hero-phone {
		display: inline-flex;
		flex-direction: column;
		margin-top: 22px;
		text-decoration: none;
		color: var(--ink);
	}

	.hero-phone-num {
		font-family: "Nunito", sans-serif;
		font-weight: 800;
		font-size: 22px;
		color: var(--ink);
	}

	.hero-phone-hint {
		font-size: 13px;
		color: var(--muted);
		letter-spacing: 0.3px;
	}

	.hero-phone:hover .hero-phone-num {
		color: var(--gold);
	}

	.hero-side {
		position: relative;
		display: grid;
		gap: 16px;
	}

	.hero-media {
		position: relative;
		max-width: 460px;
		margin-left: auto;
		width: 100%;
		box-shadow: var(--shadow-lg);
		border-radius: var(--radius-lg);
		overflow: hidden;
		aspect-ratio: 3 / 4;
	}

	.hero-img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.hero-promo {
		max-width: 460px;
		margin-left: auto;
		width: 100%;
		padding: 16px 20px;
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-sm);
	}

	.hero-promo-row {
		display: grid;
		grid-template-columns: 28px 1fr;
		gap: 12px;
		align-items: start;
	}

	.hero-promo-row svg {
		width: 28px;
		height: 28px;
		color: var(--gold);
		flex-shrink: 0;
	}

	.hero-promo-row strong {
		display: block;
		font-family: "Nunito", sans-serif;
		font-size: 15px;
		color: var(--ink);
		margin-bottom: 2px;
	}

	.hero-promo-row span {
		display: block;
		font-size: 13px;
		color: var(--muted);
		line-height: 1.5;
	}

	@media (max-width: 880px) {
		.hero-grid {
			grid-template-columns: 1fr;
		}

		.hero-side {
			order: -1;
		}

		.hero-media,
		.hero-promo {
			max-width: 100%;
			margin-left: 0;
		}
	}
</style>
