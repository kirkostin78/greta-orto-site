---
const year = new Date().getFullYear();

const footerColumns = [
	{
		title: "Лечение",
		items: [
			{ href: "/elajnery/", label: "Элайнеры" },
			{ href: "/brekety/", label: "Брекеты" },
			{ href: "/prikus/", label: "Прикус" },
			{ href: "/retentsiya/", label: "Ретенция" },
		],
	},
	{
		title: "Пациентам",
		items: [
			{ href: "/detskaya-ortodontiya/", label: "Детская ортодонтия" },
			{ href: "/gnatologiya/", label: "Гнатология / ВНЧС" },
			{ href: "/ortodont/", label: "Наши врачи" },
		],
	},
	{
		title: "Клиника",
		items: [
			{ href: "/klinika/", label: "О клинике" },
			{ href: "/o-nas/", label: "О бренде Greta Orto" },
			{ href: "/kontakty/", label: "Контакты" },
		],
	},
];
---

<footer class="site-footer">
	<div class="container">
		<div class="cols">
			{
				footerColumns.map((col) => (
					<div class="col">
						<h4>{col.title}</h4>
						<ul>
							{col.items.map((it) => (
								<li>
									<a href={it.href}>{it.label}</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
		<div class="bottom">
			<span>© Грета Орто, {year}. Центр прозрачной ортодонтии в Санкт-Петербурге.</span>
			<span class="meta">Не является публичной офертой. Лицензия Л041-01148-78/00586921 (демо).</span>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 80px;
		padding: 40px 0 28px;
		background: #1f1f1f;
		color: #cfcfcf;
		font-size: 14px;
	}

	.container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.cols {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 28px;
		margin-bottom: 28px;
	}

	h4 {
		margin: 0 0 12px;
		font-family: "Nunito", system-ui, sans-serif;
		color: #fff;
		font-size: 15px;
	}

	ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 6px;
	}

	a {
		color: #cfcfcf;
		text-decoration: none;
	}

	a:hover {
		color: var(--gold);
	}

	.bottom {
		border-top: 1px solid #333;
		padding-top: 18px;
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 12px;
		font-size: 12px;
		color: #8f8f8f;
	}
</style>
