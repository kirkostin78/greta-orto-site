---
const year = new Date().getFullYear();

const phone1 = "+7 (812) 501-12-15";
const phone1Tel = "+78125011215";
const phone2 = "+7 (994) 416-85-68";
const phone2Tel = "+79944168568";

const footerColumns = [
	{
		title: "Ортодонтия",
		items: [
			{ href: "/elajnery/", label: "Элайнеры" },
			{ href: "/brekety/", label: "Брекеты" },
			{ href: "/prikus/", label: "Прикус" },
			{ href: "/retentsiya/", label: "Ретенция" },
			{ href: "/detskaya-ortodontiya/", label: "Детская ортодонтия" },
			{ href: "/gnatologiya/", label: "Гнатология / ВНЧС" },
		],
	},
	{
		title: "Также делаем",
		items: [
			{ href: "/viniry/", label: "Виниры" },
			{ href: "/implantatsiya/", label: "Имплантация" },
			{ href: "/ortodont/", label: "Наши врачи" },
		],
	},
	{
		title: "Клиника",
		items: [
			{ href: "/klinika/", label: "О клинике" },
			{ href: "/o-nas/", label: "О бренде" },
			{ href: "/kontakty/", label: "Контакты" },
		],
	},
];
---

<footer class="site-footer">
	<div class="container">
		<div class="footer-top">
			<div class="footer-brand">
				<a class="brand" href="/" aria-label="Грета Орто — на главную">
					<img
						src="/greta-orto-mark-header.png"
						srcset="/greta-orto-mark-header.png 1x, /greta-orto-mark-header@2x.png 2x"
						alt=""
						width="92"
						height="48"
						class="brand-mark"
					/>
					<span class="brand-text">
						<span class="brand-name">Грета Орто</span>
						<span class="brand-tagline">центр прозрачной ортодонтии</span>
					</span>
				</a>
				<p class="footer-about">
					Центр прозрачной ортодонтии в Санкт-Петербурге. Главный фокус — лечение на элайнерах.
					Также делаем брекеты, виниры и имплантацию для комплексных решений.
				</p>

				<div class="footer-contacts">
					<a class="footer-phone" href={`tel:${phone1Tel}`}>
						<span class="footer-phone-num">{phone1}</span>
						<span class="footer-phone-hint">Городской</span>
					</a>
					<a class="footer-phone" href={`tel:${phone2Tel}`}>
						<span class="footer-phone-num">{phone2}</span>
						<span class="footer-phone-hint">Мобильный · WhatsApp</span>
					</a>
				</div>

				<div class="footer-address">
					<div class="footer-address-line">Санкт-Петербург, ул. Марата, 68, лит. А, пом. 9-н</div>
					<div class="footer-address-line muted">Пн–Вс, 9:00–21:00 · без выходных</div>
				</div>
			</div>

			<div class="footer-cols">
				{
					footerColumns.map((col) => (
						<div class="col">
							<h4>{col.title}</h4>
							<ul>
								{col.items.map((it) => (
									<li>
										<a href={it.href}>{it.label}</a>
									</li>
								))}
							</ul>
						</div>
					))
				}
			</div>
		</div>

		<div class="bottom">
			<div class="bottom-legal">
				<div>© Грета Орто, {year}. Центр прозрачной ортодонтии в Санкт-Петербурге.</div>
				<div class="meta">
					ООО «НТВ» · ИНН 7805819155 · ОГРН 1247800108148. Информация на сайте не является публичной
					офертой и медицинской консультацией. Реквизиты и лицензия — на странице
					<a href="/klinika/">«Клиника»</a>.
				</div>
			</div>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: var(--space-section);
		padding: 56px 0 28px;
		background: var(--ink);
		color: rgba(255, 253, 250, 0.72);
		font-size: 14px;
	}

	.container {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.footer-top {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(0, 2fr);
		gap: 48px;
		padding-bottom: 36px;
		border-bottom: 1px solid rgba(255, 253, 250, 0.08);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
		margin-bottom: 18px;
	}

	.brand-mark {
		width: auto;
		height: 44px;
		filter: brightness(1.1);
	}

	.brand-text {
		display: flex;
		flex-direction: column;
		line-height: 1;
	}

	.brand-name {
		font-family: "Nunito", system-ui, sans-serif;
		font-weight: 800;
		font-size: 20px;
		color: var(--gold-soft);
		letter-spacing: -0.3px;
	}

	.brand-tagline {
		margin-top: 4px;
		font-size: 10.5px;
		color: rgba(255, 253, 250, 0.5);
		letter-spacing: 0.8px;
		text-transform: uppercase;
	}

	.footer-about {
		max-width: 36ch;
		font-size: 14px;
		line-height: 1.6;
		color: rgba(255, 253, 250, 0.65);
		margin: 0 0 22px;
	}

	.footer-contacts {
		display: grid;
		gap: 12px;
		margin-bottom: 18px;
	}

	.footer-phone {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: rgba(255, 253, 250, 0.85);
	}

	.footer-phone-num {
		font-family: "Nunito", sans-serif;
		font-weight: 800;
		font-size: 19px;
		color: #fff;
	}

	.footer-phone-hint {
		margin-top: 2px;
		font-size: 12px;
		color: rgba(255, 253, 250, 0.5);
	}

	.footer-phone:hover .footer-phone-num {
		color: var(--gold-soft);
	}

	.footer-address {
		font-size: 13.5px;
		line-height: 1.55;
		color: rgba(255, 253, 250, 0.78);
	}

	.footer-address-line.muted {
		color: rgba(255, 253, 250, 0.5);
		font-size: 12.5px;
		margin-top: 2px;
	}

	.footer-cols {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		gap: 32px;
	}

	h4 {
		margin: 0 0 14px;
		font-family: "Nunito", sans-serif;
		color: #fff;
		font-size: 14px;
		letter-spacing: 0.4px;
		text-transform: uppercase;
		font-weight: 700;
	}

	ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 8px;
	}

	.footer-cols a {
		color: rgba(255, 253, 250, 0.72);
		text-decoration: none;
		transition: color 0.15s;
	}

	.footer-cols a:hover {
		color: var(--gold-soft);
	}

	.bottom {
		padding-top: 22px;
	}

	.bottom-legal {
		display: grid;
		gap: 8px;
		font-size: 12.5px;
		color: rgba(255, 253, 250, 0.45);
	}

	.bottom .meta {
		max-width: 80ch;
	}

	.bottom a {
		color: rgba(255, 253, 250, 0.65);
		text-decoration: underline;
	}

	@media (max-width: 880px) {
		.footer-top {
			grid-template-columns: 1fr;
			gap: 32px;
		}
	}
</style>
